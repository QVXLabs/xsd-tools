#ifndef XSDTOOLS_VERSION_H_
#define XSDTOOLS_VERSION_H_

/* Display version: the VERSION-file base, decorated with a git suffix for
 * dev builds (e.g. 0.2.0+7.gab12cd.dirty); a release stamps the tag, clean. */
#define XSDTOOLS_VERSION "@XSD_VERSION_FULL@"

/* Numeric components (from project(VERSION ...)). */
#define XSDTOOLS_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define XSDTOOLS_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define XSDTOOLS_VERSION_PATCH @PROJECT_VERSION_PATCH@

#endif /* XSDTOOLS_VERSION_H_ */
