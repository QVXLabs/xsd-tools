[@lua --define python list long type (JSON)
	pyjsontype_listLong = {
		marshal = {
			attribute = function(wire, ident)
				return table.concat({
					"        if self._", ident, " is not None:\n",
					"            attrs[\"", wire, "\"] = [int(x) for x in self._", ident, "]\n",
				})
			end,
			content = function()
				return table.concat({
					"        content = [int(x) for x in self.getContent()]\n"
				})
			end,
		},
		unmarshal = {
			attribute = function(wire, ident)
				return table.concat({
					"            if \"", wire, "\" == attribute:\n",
					"                self._", ident, " = [int(x) for x in attributes[attribute]]\n",
				})
			end,
			content = function()
				return table.concat({
					"        self._content = [int(x) for x in content]\n"
				})
			end
		},
		default = function(ident, value)
			return table.concat({"        self._", ident, " = [int(x) for x in ", pyQuote(value), ".split()]\n"})
		end,
