[@lua
include 'includes/c-xml-expat-dom/baseType'

short = {}
short.__index = short
setmetatable(short, {__index = baseType})

function short:new(typeFactory, typedef)
   local retObj = baseType:new(typeFactory, typedef)
   setmetatable(retObj, short)
   return retObj
end

function short:typeName()
   return ("xml_short")
end

function short:inlineScalar()
   return true
end

function short:cType()
   return "int16_t"
end

function short:typeDef()
   return self:scalarTypeDef()
end

function short:typeFactoryMethods()
   return ""
end

function short:defMarshal(elementName)
   return self:defScalarMarshal(function(v)
      return ("  char num[8];\n  snprintf(num, 8, \"%%d\", %s);\n  cstr_append_(ppOut, num, pFactory);\n"):format(v)
   end)
end

function short:defUnmarshal(elementName)
   return self:defScalarUnmarshal("(int16_t)atoll(pVal)")
end

function short:defDestroy()
   return self:defScalarDestroy()
end

function short:test(facets)
   return facets_sampleInt(facets) or "29832"
end
