[@lua -- Reserved code-identifiers for the cpp-xml-expat target: C++ keywords
	-- the sanitizer must avoid, this target's framework type names (an element
	-- named e.g. "Factory" would else redefine the generated class), and the
	-- content_ bookkeeping base (an attribute named "content" would else map to
	-- the same member as the text-content field). Passed to c_safeNames() by both
	-- the binding and -test templates so their idents agree.
	CPP_KEYWORDS = {}
	local function reserve(list)
		for w in list:gmatch('%S+') do CPP_KEYWORDS[w] = true end
	end
	reserve[[
		alignas alignof and and_eq asm auto bitand bitor bool break case catch
		char char16_t char32_t class compl const constexpr const_cast continue
		decltype default delete do double dynamic_cast else enum explicit export
		extern false float for friend goto if inline int long mutable namespace
		new noexcept not not_eq nullptr operator or or_eq private protected public
		register reinterpret_cast return short signed sizeof static static_assert
		static_cast struct switch template this thread_local throw true try typedef
		typeid typename union unsigned using virtual void volatile wchar_t while
		xor xor_eq
	]]
	-- target framework identifiers + content_ member base
	reserve[[ Element Factory Marshaller ParseRec MarshalRec content ]]
]