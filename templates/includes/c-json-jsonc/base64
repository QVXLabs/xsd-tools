[@lua --define json_base64 type
	ctype_base64 = {
		type = 'c_type',
		c_type = {
			name = function()
				return 'json_base64'
			end,
			definition = function()
				return table.concat({
					'typedef struct {\n',
					'\tuint8_t*\tpBuffer_;\n',
					'\tuint32_t\tsize_;\n',
					'} json_base64;\n',
				})
			end,
			statement = function(varName)
				return table.concat({
					'json_base64\t', varName, '_;\n',
				})
			end,
		},
		delete = {
			definition = function()
				return table.concat({
					'static void destroy_jsonbase64_(json_marshaller* pMarshaller, json_base64* pObj) {\n',
					'\tif(pObj->pBuffer_) {\n',
					'\t\tpObj->pBuffer_ = pMarshaller->realloc(pMarshaller, pObj->pBuffer_, 0);\n',
					'\t}\n',
					'}\n',
				})
			end,
			statement = function(obj)
				return table.concat({
					'destroy_jsonbase64_(pMarshaller, &', obj, ');\n',
				})
			end,
		},
		buildVar = function(obj, member)
			return table.concat({obj,member,'_'})
		end,
		binding = {
			marshal = {
				definition = function()
					return table.concat({
						-- Adapter so libb64 2.1 routes its output allocation
						-- through the marshaller. Emitted once (base64 type is
						-- defined once); reused by unmarshal.
						'static void* jsonbase64_realloc_(void* ctx, void* ptr, size_t size, b64_memlife life) {\n',
						'\tjson_marshaller* pMarshaller = (json_marshaller*)ctx;\n',
						'\t(void)life;\n',
						'\treturn pMarshaller->realloc(pMarshaller, ptr, size);\n',
						'}\n',
						'static struct json_object* marshal_jsonbase64_(json_marshaller* pMarshaller, const json_base64* pObj) {\n',
						'\tb64_allocator b64Alloc = base64_allocator(jsonbase64_realloc_, pMarshaller);\n',
						'\tchar* outStr = NULL;\n',
						'\tsize_t outLen = 0;\n',
						'\tstruct json_object* pRet;\n',
						'\tbase64_encode_alloc(&b64Alloc, pObj->pBuffer_, pObj->size_, &outStr, &outLen);\n',
						'\tpRet = json_object_new_string(outStr);\n',
						'\tbase64_free(&b64Alloc, outStr);\n',
						'\treturn pRet;\n',
						'}\n',
					})
				end,
				value = function(obj)
					return table.concat({'marshal_jsonbase64_(pMarshaller, &', obj, ')'})
				end,
				statement = function(dst, key, obj)
					return table.concat({
						'json_object_object_add(', dst, ', ', key,
						', marshal_jsonbase64_(pMarshaller, &', obj, '));\n',
					})
				end,
			},
			unmarshal = {
				definition = function()
					return table.concat({
						'static void unmarshal_jsonbase64_(json_marshaller* pMarshaller, const char* restrict pContent, json_base64* restrict pObj) {\n',
						'\tb64_allocator b64Alloc = base64_allocator(jsonbase64_realloc_, pMarshaller);\n',
						'\tvoid* pData = NULL;\n',
						'\tsize_t outLen = 0;\n',
						'\tbase64_decode_alloc(&b64Alloc, pContent, strlen(pContent), &pData, &outLen);\n',
						'\tpObj->pBuffer_ = (uint8_t*)pData;\n',
						'\tpObj->size_ = (uint32_t)outLen;\n',
						'}\n',
					})
				end,
				statement = function(src, obj)
					return table.concat({
						'unmarshal_jsonbase64_(pMarshaller, json_object_get_string(', src, '), &', obj, ');\n',
					})
				end,
			},
		},
		test = {
			assign = function()
				local str = string.format(
					'%X%X%X',
					math.random(0, 65535),
					math.random(0, 65535),
					math.random(0, 65535)
				)
				return string.format('{ .pBuffer_ = (uint8_t*)\"%s\", .size_ = %d }', str, str:len())
			end,
			assert = function(obj1, obj2)
				return table.concat({
					string.format("\tassert(%s.size_ ==  %s.size_);\n", obj1, obj2),
					string.format("\tassert(!memcmp(%s.pBuffer_, %s.pBuffer_, %s.size_));\n", obj1, obj2, obj2),
				})
			end
		},
	}
]
