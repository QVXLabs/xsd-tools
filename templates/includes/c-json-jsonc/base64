[@lua --define json_base64 type
	ctype_base64 = {
		type = 'c_type',
		c_type = {
			name = function()
				return 'json_base64'
			end,
			definition = function()
				return table.concat({
					'typedef struct {\n',
					'\tuint8_t*\tpBuffer_;\n',
					'\tuint32_t\tsize_;\n',
					'} json_base64;\n',
				})
			end,
			statement = function(varName)
				return table.concat({
					'json_base64\t', varName, '_;\n',
				})
			end,
		},
		delete = {
			definition = function()
				return table.concat({
					'static void destroy_jsonbase64_(json_marshaller* pMarshaller, json_base64* pObj) {\n',
					'\tif(pObj->pBuffer_) {\n',
					'\t\tpObj->pBuffer_ = pMarshaller->realloc(pMarshaller, pObj->pBuffer_, 0);\n',
					'\t}\n',
					'}\n',
				})
			end,
			statement = function(obj)
				return table.concat({
					'destroy_jsonbase64_(pMarshaller, &', obj, ');\n',
				})
			end,
		},
		buildVar = function(obj, member)
			return table.concat({obj,member,'_'})
		end,
		binding = {
			marshal = {
				definition = function()
					return table.concat({
						'static struct json_object* marshal_jsonbase64_(json_marshaller* pMarshaller, const json_base64* pObj) {\n',
						'\tbase64_encodestate base64Encoder;\n',
						'\tconst size_t srcSz = pObj->size_;\n',
						'\tconst size_t b64Sz = ((srcSz + 2 - ((srcSz + 2) % 3)) / 3 * 4) + 2;\n',
						'\tsize_t encodedCnt = 0;\n',
						'\tstruct json_object* pRet;\n',
						'\tchar* outStr = pMarshaller->realloc(pMarshaller, NULL, b64Sz);\n',
						'\tmemset(outStr, 0, b64Sz);\n',
						'\tbase64_init_encodestate(&base64Encoder);\n',
						'\tencodedCnt = base64_encode_block((const char*)pObj->pBuffer_, srcSz, outStr, &base64Encoder);\n',
						'\tbase64_encode_blockend(outStr + encodedCnt, &base64Encoder);\n',
						'\tpRet = json_object_new_string(outStr);\n',
						'\tpMarshaller->realloc(pMarshaller, outStr, 0);\n',
						'\treturn pRet;\n',
						'}\n',
					})
				end,
				value = function(obj)
					return table.concat({'marshal_jsonbase64_(pMarshaller, &', obj, ')'})
				end,
				statement = function(dst, key, obj)
					return table.concat({
						'json_object_object_add(', dst, ', ', key,
						', marshal_jsonbase64_(pMarshaller, &', obj, '));\n',
					})
				end,
			},
			unmarshal = {
				definition = function()
					return table.concat({
						'static void unmarshal_jsonbase64_(json_marshaller* pMarshaller, const char* restrict pContent, json_base64* restrict pObj) {\n',
						'\tbase64_decodestate base64Decoder;\n',
						'\tconst size_t srcLen = strlen(pContent);\n',
						'\tconst size_t dataSz = ((srcLen * 3) / 4) + 1;\n',
						'\tint decoded;\n',
						'\tpObj->pBuffer_ = pMarshaller->realloc(pMarshaller, NULL, dataSz);\n',
						'\tmemset(pObj->pBuffer_, 0, dataSz);\n',
						'\tbase64_init_decodestate(&base64Decoder);\n',
						'\tdecoded = base64_decode_block(pContent, srcLen, (char*)pObj->pBuffer_, &base64Decoder);\n',
						'\tpObj->size_ = (uint32_t)decoded;\n',
						'}\n',
					})
				end,
				statement = function(src, obj)
					return table.concat({
						'unmarshal_jsonbase64_(pMarshaller, json_object_get_string(', src, '), &', obj, ');\n',
					})
				end,
			},
		},
		test = {
			assign = function()
				local str = string.format(
					'%X%X%X',
					math.random(0, 65535),
					math.random(0, 65535),
					math.random(0, 65535)
				)
				return string.format('{ .pBuffer_ = (uint8_t*)\"%s\", .size_ = %d }', str, str:len())
			end,
			assert = function(obj1, obj2)
				return table.concat({
					string.format("\tassert(%s.size_ ==  %s.size_);\n", obj1, obj2),
					string.format("\tassert(!memcmp(%s.pBuffer_, %s.pBuffer_, %s.size_));\n", obj1, obj2, obj2),
				})
			end
		},
	}
]
