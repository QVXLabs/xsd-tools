[@lua --Java reserved-identifier set for the contract sanitizer.
	-- Passed to schema.c_safeNames so BOTH type (class) idents and attribute
	-- accessor idents avoid: Java keywords; java.lang.Object methods that would
	-- collide with a generated accessor; the Element base class's members
	-- (fields prefixed '_' and its methods) that a subclass field/accessor
	-- would shadow; and the framework class names this target emits.
	JAVA_KEYWORDS = {
		['abstract']=true, ['assert']=true, ['boolean']=true, ['break']=true,
		['byte']=true, ['case']=true, ['catch']=true, ['char']=true,
		['class']=true, ['const']=true, ['continue']=true, ['default']=true,
		['do']=true, ['double']=true, ['else']=true, ['enum']=true,
		['extends']=true, ['final']=true, ['finally']=true, ['float']=true,
		['for']=true, ['goto']=true, ['if']=true, ['implements']=true,
		['import']=true, ['instanceof']=true, ['int']=true, ['interface']=true,
		['long']=true, ['native']=true, ['new']=true, ['package']=true,
		['private']=true, ['protected']=true, ['public']=true, ['return']=true,
		['short']=true, ['static']=true, ['strictfp']=true, ['super']=true,
		['switch']=true, ['synchronized']=true, ['this']=true, ['throw']=true,
		['throws']=true, ['transient']=true, ['try']=true, ['void']=true,
		['volatile']=true, ['while']=true, ['true']=true, ['false']=true,
		['null']=true, ['record']=true, ['var']=true, ['yield']=true,
		-- java.lang.Object methods (getClass/etc. are final -> override = error)
		['getClass']=true, ['hashCode']=true, ['equals']=true, ['clone']=true,
		['toString']=true, ['wait']=true, ['notify']=true, ['notifyAll']=true,
		['finalize']=true,
		-- Element base members: '_'-prefixed fields and its methods, so a
		-- subclass field (_ident) or accessor (ident()) can't shadow them
		['buf']=true, ['children']=true, ['factory']=true, ['text']=true,
		['localName']=true, ['namespaceURI']=true, ['marshal']=true,
		['marshalNamespaces']=true, ['marshalAttributes']=true,
		['marshalContent']=true, ['readContent']=true, ['unmarshal']=true,
		['validate']=true,
		-- framework class names this target emits (block same-name type idents)
		['Element']=true, ['Factory']=true, ['Document']=true, ['Hex']=true,
	}
	-- Case-insensitive framework-file guard: a type ident matching a framework
	-- class name only by case would overwrite its file on a case-insensitive
	-- filesystem (macOS/Windows). c_safeNames only de-collides exact matches,
	-- so fix up case variants here.
	local frameworkFiles = {
		['element']=true, ['factory']=true, ['document']=true, ['hex']=true,
	}
	function guardFrameworkNames(schema)
		for _, t in pairs(schema.types) do
			while frameworkFiles[t.ident:lower()] do t.ident = t.ident.."_" end
		end
	end
	-- Turn a topo-ordered dep list into the emit list: fill idents for orphaned
	-- dependents (structural duplicates the model's dedup evicted from
	-- schema.types) from their surviving twin, drop the root, and collapse
	-- duplicate idents so each class / Factory entry emits exactly once.
	function normalizeDepList(schema, depOrder)
		local identForName, registered = {}, {}
		for _, t in pairs(schema.types) do
			registered[t] = true
			-- prefer the un-suffixed original (regkey == wire name)
			if identForName[t.name] == nil or t.regkey == t.name then
				identForName[t.name] = t.ident
			end
		end
		-- one node per ident, preferring the registered twin: the orphan lacks
		-- attribute idents, so emitting from it would nil-crash.
		local pick, order = {}, {}
		for _, v in ipairs(depOrder) do
			if not v.ident then v.ident = identForName[v.name] end
			if v.name ~= schema.root and v.ident then
				if pick[v.ident] == nil then
					pick[v.ident] = v
					order[#order + 1] = v.ident
				elseif registered[v] and not registered[pick[v.ident]] then
					pick[v.ident] = v
				end
			end
		end
		local out = {}
		for _, id in ipairs(order) do out[#out + 1] = pick[id] end
		return out
	end
]
