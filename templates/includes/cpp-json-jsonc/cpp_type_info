	-- D2b: map a {bits, signed} narrowing to its fixed-width ctype.
	local cpp_narrowMap = {
		['8|true'] = ctype_int8t,   ['16|true'] = ctype_int16t,
		['32|true'] = ctype_int32t, ['64|true'] = ctype_int64t,
