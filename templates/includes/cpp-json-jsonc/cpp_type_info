		['32|false'] = ctype_uint32t, ['64|false'] = ctype_uint64t,
	}

	-- Effective ctype for an XSD type given its facets: the narrowest int that
	-- holds the facet range when both bounds are known, else the default. Only
	-- narrows scalar integer ctypes (skips strings, floats, lists, base64/hex).
	local cpp_intTypes = {
		[ctype_int8t]=true, [ctype_int16t]=true, [ctype_int32t]=true,
		[ctype_int64t]=true, [ctype_uint8t]=true, [ctype_uint16t]=true,
		[ctype_uint32t]=true, [ctype_uint64t]=true,
	}
	function cpp_narrowType(xsdType, facets)
		return facets_narrowType(cpp_type_info[xsdType], facets, cpp_narrowMap, cpp_intTypes)
	end

	-- Reserved C++ identifiers passed to c_safeNames so wire names that collide
	-- with a keyword or a bookkeeping class member (eid_/Content) get a safe
	-- .ident. Seeded here since the class layout is target-specific.
	cpp_keywords = {}
	for _, w in ipairs({
		'alignas','alignof','and','and_eq','asm','auto','bitand','bitor',
