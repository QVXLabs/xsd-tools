[@lua --define base64 type (std::vector<uint8_t> + libb64)
	ctype_base64 = {
		type = 'cpp_type',
		tag = 'base64',
		cpp_type = {
			name = function() return 'std::vector<uint8_t>' end,
			definition = function() return '' end,
			statement = function(varName)
				return 'std::vector<uint8_t>\t'..varName..'_;\n'
			end,
		},
		buildVar = function(obj, member) return table.concat({obj, member, '_'}) end,
		binding = {
			marshal = {
				definition = function()
					return table.concat({
						'json_object* _marshal_base64(const std::vector<uint8_t>& data) {\n',
						'\tbase64::encoder enc = base64::encoder_builder().build();\n',
						'\tconst size_t srcSz = data.size();\n',
						'\tstd::vector<char> out(((srcSz + 2) / 3) * 4 + 2, 0);\n',
						'\tconst char* pSrc = srcSz ? reinterpret_cast<const char*>(&data[0]) : "";\n',
						'\tstd::streamsize n = enc.encode(pSrc, (std::streamsize)srcSz, &out[0]);\n',
						'\tn += enc.encode_end(&out[n]);\n',
						'\treturn json_object_new_string_len(&out[0], (int)n);\n',
						'}\n',
					})
				end,
				value = function(obj) return '_marshal_base64('..obj..')' end,
				statement = function(dst, key, obj)
					return 'json_object_object_add('..dst..', '..key..', _marshal_base64('..obj..'));\n'
				end,
			},
			unmarshal = {
				definition = function()
					return table.concat({
						'void _unmarshal_base64(const char* pStr, std::vector<uint8_t>& out) {\n',
						'\tbase64::decoder dec = base64::decoder_builder().build();\n',
						'\tconst size_t srcLen = pStr ? strlen(pStr) : 0;\n',
						'\tout.assign((srcLen * 3) / 4 + 1, 0);\n',
						'\tstd::streamsize n = dec.decode(pStr ? pStr : "", (std::streamsize)srcLen, reinterpret_cast<char*>(&out[0]));\n',
						'\tout.resize(n > 0 ? (size_t)n : 0);\n',
						'}\n',
					})
				end,
				statement = function(src, obj)
					return '_unmarshal_base64(json_object_get_string('..src..'), '..obj..');\n'
				end,
			},
		},
		test = {
			assign = function()
				local n = math.random(1, 6)
				local bytes = {}
				for _ = 1, n do bytes[#bytes + 1] = math.random(0, 255) end
				return '{ '..table.concat(bytes, ', ')..' }'
			end,
			assert = function(obj1, obj2)
				return string.format("\tassert(%s == %s);\n", obj1, obj2)
			end
		},
	}
]
