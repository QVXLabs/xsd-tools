[@lua --define float type
	ctype_float = {
		type = 'c_type',
		c_type = {
			name = function() 
				return 'float'
			end,
			definition = function() 
				return ''
			end,
			statement = function(varName) 
				return table.concat({
					'float\t', varName, '_;\n',
				})
			end,
		},
		delete = {
			definition = function() 
				return ''
			end,
			statement = function(obj) 
				return ''
			end,
		},
		buildVar = function(obj, member) 
			return table.concat({obj,member,'_'})
		end,
		binding = {
			marshal = {
				definition = function() 
					return table.concat({
						'void marshal_float_(xml_marshaller* pMarshaller, xml_cstr* pOutStr, const float val) {\n',
						'\tchar valBuf[128];\n',
						'\tsnprintf(valBuf, sizeof(valBuf), "%f", val);\n',
						'\tcstr_append_(pMarshaller, pOutStr, valBuf);\n',
						'}\n',
					})
				end,
				statement = function(dst, obj)
					return table.concat({
						'marshal_float_(pMarshaller, ', dst, ', ', obj, ');\n',
					})
				end,
			},
			unmarshal = {
				definition = function() 
					return ''
				end,
				statement = function(src, obj)
					return table.concat({
						obj, ' = (float)atof(', src, ');\n',
					})
				end,
			},
		},
		test = {
			assign = function()
				return tostring(math.random() * math.random(-127, 127))
			end,
			assert = function(obj1, obj2)
				return string.format("assert(%s == %s);\n", obj1, obj2)
			end
		},
	}
]