[@lua
include 'c-xml-expat-dom/baseType'

integer = {}
integer.__index = integer
setmetatable(integer, {__index = baseType})

function integer:new(typeFactory, typedef)
   local retObj = baseType:new(typeFactory, typedef)
   setmetatable(retObj, integer)
   return retObj
end

function integer:instanceOf()
   return "integer"
end

function integer:typeName()
   return ("xml_integer")
end

function integer:inlineScalar()
   return true
end

function integer:cType()
   return "int64_t"
end

function integer:typeDef()
   return self:scalarTypeDef()
end

function integer:typeFactoryMethods()
   return ""
end

function integer:defMarshal(elementName)
   return self:defScalarMarshal(function(v)
      return ("  char num[64];\n  snprintf(num, 64, \"%%\" PRId64, %s);\n  cstr_append_(ppOut, num, pFactory);\n"):format(v)
   end)
end

function integer:defUnmarshal(elementName)
   return self:defScalarUnmarshal("(int64_t)atoll(pVal)")
end

function integer:defDestroy()
   return self:defScalarDestroy()
end

function integer:test(facets)
   return facets_sampleInt(facets) or "463"
end
]
