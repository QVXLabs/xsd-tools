  exit(1);
}
/* ------------ */
static XML_Memory_Handling_Suite *
XML_initMemSuite_(const xml_typeFactory * pFactory) {
  static XML_Memory_Handling_Suite gsMemSuite = {
    .malloc_fcn = malloc_,
    .realloc_fcn = realloc_,
    .free_fcn = free_
  };
  return &gsMemSuite;
}
/* ------------ */
static void *
xml_realloc_(const xml_typeFactory * pFactory, void * pMem, size_t size, const char * pFileName, const unsigned lineNo) {
  if (pFactory && pFactory->xml_realloc)
    return pFactory->xml_realloc(pFactory, pMem, size, pFileName, lineNo);
  else {
    pMem = realloc(pMem, size);
    if (pMem && !size) free(pMem);
    return pMem;
  }
}
/* ------------ */
static void * 
malloc_(size_t size) {
  return xml_realloc_(gspFactory, NULL, size, __FILE__, __LINE__);
}
/* ------------ */
static void * 
realloc_(void * pMem, size_t size) {
  return xml_realloc_(gspFactory, pMem, size, __FILE__, __LINE__);
}
/* ------------ */
static void 
free_(void* pMem) {
  xml_realloc_(gspFactory, pMem, 0, __FILE__, __LINE__);
}
/* ------------ */
static void *
alloc_(size_t size, const xml_typeFactory * pFactory) {
  return memset(ReallocateMemory(pFactory, NULL, size), 0, size);
}
/* ------------ */
static xml_list_t_ 
list_(const size_t elmsz, const xml_typeFactory * pFactory) {
  xml_list_t_ ret = { 
    .elmSz_ = elmsz, 
    .alloc_ = 4, 
    .size_ = 0,
    .pMem_ = ReallocateMemory(pFactory, NULL, ret.alloc_ * ret.elmSz_)
  };
  return ret;
}
/* ------------ */
static inline void
list_push_(xml_list_t_ * pLst, const void * const pObj, const xml_typeFactory * pFactory) {
  if (pLst->size_ == pLst->alloc_) {
    pLst->pMem_ = ReallocateMemory(pFactory, pLst->pMem_, (pLst->alloc_ <<=1) * pLst->elmSz_);
  }
  memcpy(pLst->pMem_ + (pLst->elmSz_ * pLst->size_), pObj, pLst->elmSz_);
  pLst->size_++;
}
/* ------------ */
/* Realloc-down to exact size: used by LIST-type unmarshal whose c-array is
   iterated by count (no sentinel). The DOM content list is sentinel-
   terminated and skips this, so this is unused for list-free schemas. */
__attribute__((__unused__)) static void
list_trim_(xml_list_t_ * pLst, const xml_typeFactory * pFactory) {
  pLst->alloc_ = pLst->size_;
  pLst->pMem_ = ReallocateMemory(pFactory, pLst->pMem_, pLst->alloc_ * pLst->elmSz_);
}
/* ------------ */
static inline void *
list_carray_(xml_list_t_ * pLst) {
  return pLst->pMem_;
}
