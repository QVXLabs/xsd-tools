static void
context_pushElement_(xml_context_t_ * pCtx, xml_typelist element) {
  const unsigned ndx = pCtx->depth_++;
  pCtx->stack_[ndx].element_ = element;
  pCtx->stack_[ndx].cntntLst_ = list_(sizeof(xml_typelist), pCtx->pFactory_);
  pCtx->stack_[ndx].pContent_ = NULL;
}
/* ------------ */
static xml_typelist *
context_topElement_(xml_context_t_ * pCtx) {
  const int ndx = pCtx->depth_ - 1;
  return (ndx > - 1) ? &pCtx->stack_[ndx].element_ : NULL;
}
/* ------------ */
static void
context_popElement_(xml_context_t_ * pCtx) {
  xml_stack_t_  * pStack     = &pCtx->stack_[--(pCtx->depth_)];
  xml_typelist ** ppCntntLst = (xml_typelist **)pStack->element_.pData_;
  xml_typelist term = { 0, NULL };
  /* Terminator-pushed list iterates to the {0,NULL} sentinel, so the spare
     capacity past size_ is never read — skip the realloc-down trim. */
  list_push_(&pStack->cntntLst_, &term, pCtx->pFactory_);
  *ppCntntLst = list_carray_(&pStack->cntntLst_);
  cstr_destroy_(&pStack->pContent_, pCtx->pFactory_);
}
/* ------------ */
static void
context_addContent_(xml_context_t_ * pCtx, xml_typelist content) {
  const int ndx      = pCtx->depth_ - 1;
  if (ndx > -1) {
    xml_list_t_  * pContent = &pCtx->stack_[ndx].cntntLst_;
    list_push_(pContent, &content, pCtx->pFactory_);
  }
}
/* ------------ */
static const char *
context_contentStr_(xml_context_t_ * pCtx) {
  const int ndx = pCtx->depth_ - 1;
  return (ndx > -1) ? pCtx->stack_[ndx].pContent_ : NULL;
}
/* ------------ */
static void
content_addContentStr_(xml_context_t_ * pCtx, const char * pStr, unsigned len) {
  const int ndx = pCtx->depth_ - 1;
  if (ndx > -1)
    cstr_appendEx_(&pCtx->stack_[ndx].pContent_, pStr, len, pCtx->pFactory_);
}
/* ------------ */
__attribute__((__unused__)) static char *
content_popContentStr_(xml_context_t_ * pCtx) {
  const int ndx = pCtx->depth_ - 1;
  char * pRetVal = NULL;
  if (ndx > -1) {
    pRetVal = pCtx->stack_[ndx].pContent_;
    pCtx->stack_[ndx].pContent_ = NULL;
  }
  return pRetVal;
}
