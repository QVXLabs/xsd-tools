__thread const xml_typeFactory * gspFactory = NULL;
/* ------------ */
xml_typelist *
xml_unmarshal(const char * pBuf, size_t size, const xml_typeFactory * pFactory) {
  xml_typelist * pRetObj = ReallocateMemory(pFactory, 0, sizeof(xml_typelist) * 2);
  xml_context_t_ ctx = { 
    .depth_ = 0, 
    .unknownElm_ = 0, 
    .pFactory_ = pFactory 
  };
  XML_Parser parser = XML_ParserCreate_MM(NULL, XML_initMemSuite_(pFactory), NULL);
  /* zero out return block */
  memset(pRetObj, 0, sizeof(xml_typelist) * 2);
  /* parse xml document */
  gspFactory = pFactory;
  XML_SetUserData(parser, &ctx);
  XML_SetElementHandler(parser, startElement_, endElement_);
  XML_SetCharacterDataHandler(parser, elementContent_);
  XML_Parse(parser, pBuf, size, XML_TRUE);
  XML_ParserFree(parser);
  /* return root element */
  *pRetObj = ctx.stack_[0].element_;
  return pRetObj;
}
/* ------------ */
char *
xml_marshal(const xml_typelist * pDoc, const xml_typeFactory * pFactory) {
  char * pBuf = cstr_init_("<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n", -1, pFactory);
  char * pRet;
  size_t len;
  xml_typelist_marshal_(pDoc, &pBuf, pFactory);
  /* Hand back a plain buffer (no hidden header) so callers can free() it. */
  len = CSTR_HDR_(pBuf)->len_;
  pRet = memcpy(ReallocateMemory(pFactory, NULL, len + 1), pBuf, len + 1);
  cstr_destroy_(&pBuf, pFactory);
  return pRet;
}
