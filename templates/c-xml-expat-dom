/* Grow buffer behind *ppDst to hold len_ + extra bytes; doubling capacity. */
static inline void
cstr_reserve_(char ** ppDst, size_t extra, const xml_typeFactory * pFactory) {
  cstr_hdr_t_ * pHdr = *ppDst ? CSTR_HDR_(*ppDst) : NULL;
  size_t len = pHdr ? pHdr->len_ : 0;
  size_t cap = pHdr ? pHdr->cap_ : 0;
  if (len + extra + 1 > cap) {
    cap = cap ? cap : 16;
    while (len + extra + 1 > cap) cap <<= 1;
    pHdr = ReallocateMemory(pFactory, pHdr, sizeof(cstr_hdr_t_) + cap);
    pHdr->len_ = len;
    pHdr->cap_ = cap;
    *ppDst = CSTR_DATA_(pHdr);
  }
}
/* ------------ */
static char *
cstr_init_(const char * restrict pSrc, size_t len, const xml_typeFactory * pFactory) {
  size_t strLen = ((len == -1) ? strlen(pSrc) : len);
  char * pRet = NULL;
  cstr_reserve_(&pRet, strLen, pFactory);
  memcpy(pRet, pSrc, strLen);
  pRet[strLen] = 0;
  CSTR_HDR_(pRet)->len_ = strLen;
  return pRet;
}
/* ------------ */
static void
cstr_destroy_(char ** ppSrc, const xml_typeFactory * pFactory) {
  if (*ppSrc) {
    ReallocateMemory(pFactory, CSTR_HDR_(*ppSrc), 0);
    *ppSrc = NULL;
  }
}
/* ------------ */
static inline void
cstr_appendEx_(char ** restrict ppDst, const char * restrict pSrc, unsigned size, const xml_typeFactory * pFactory) {
  size_t add = pSrc ? size : 0;
  size_t len;
  cstr_reserve_(ppDst, add, pFactory);
  len = CSTR_HDR_(*ppDst)->len_;
  memcpy(*ppDst + len, pSrc, add);
  len += add;
  (*ppDst)[len] = 0;
  CSTR_HDR_(*ppDst)->len_ = len;
}
/* ------------ */
static inline void
cstr_append_(char ** restrict ppDst, const char * restrict pSrc, const xml_typeFactory * pFactory) {
  cstr_appendEx_(ppDst, pSrc, pSrc ? (unsigned)strlen(pSrc) : 0, pFactory);
}
