__attribute__((__unused__)) static xml_tokenizer_t_
tokenizer_(const char * pStr, const xml_typeFactory * pFactory) {
  xml_tokenizer_t_ ret;
  ret.pItr_ = ret.pStr_ = cstr_init_(pStr, -1, pFactory);
  return ret;
}
/* ------------ */
__attribute__((__unused__)) static const char *
tokenizer_next_(xml_tokenizer_t_ * const pTknzr) {
  const char * pRetStr = pTknzr->pItr_;  
  if (*pRetStr) {
    for (; *pTknzr->pItr_ && !isspace(*pTknzr->pItr_); ++pTknzr->pItr_) {}
    for (; *pTknzr->pItr_ && isspace(*pTknzr->pItr_); ++pTknzr->pItr_) {
      *pTknzr->pItr_ = 0;
    }
  } 
  return pRetStr;
}
/* ------------ */
__attribute__((__unused__)) void 
tokenizer_destroy_(xml_tokenizer_t_ * const pTknzr, const xml_typeFactory * pFactory) {
  cstr_destroy_(&pTknzr->pStr_, pFactory);
}
