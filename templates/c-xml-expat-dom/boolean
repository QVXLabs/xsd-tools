[@lua
include 'c-xml-expat-dom/baseType'

boolean = {}
boolean.__index = boolean
setmetatable(boolean, {__index = baseType})

function boolean:new(typeFactory, typedef)
   local retObj = baseType:new(typeFactory, typedef)
   setmetatable(retObj, boolean)
   return retObj
end

function boolean:typeName()
   return ("xml_boolean")
end

function boolean:inlineScalar()
   return true
end

function boolean:cType()
   return "unsigned"
end

function boolean:typeDef()
   return self:scalarTypeDef()
end

function boolean:typeFactoryMethods()
   return ""
end

function boolean:defMarshal(elementName)
   return self:defScalarMarshal(function(v)
      return ("  cstr_append_(ppOut, (%s ? \"true\" : \"false\"), pFactory);\n"):format(v)
   end)
end

function boolean:defUnmarshal(elementName)
   out = stringBuffer:new()
   out:append("static void *\n")
   out:append("xml_boolean_unmarshal_(const char * pStr, const xml_typeFactory * pFactory) {\n")
   out:append("  void * slot;\n")
   out:append("  unsigned v = (unsigned)strtoul(pStr, NULL, 10);\n")
   out:append("  if (!v) v = (0 == strncasecmp(pStr, \"true\", 6));\n")
   out:append("  XML_SCALAR_ENCODE_(unsigned, slot, v, pFactory);\n")
   out:append("  return slot;\n")
   out:append("}\n")
   return out:str()
end

function boolean:defDestroy()
   return self:defScalarDestroy()
end

function boolean:test()
   return "True"
end
]
