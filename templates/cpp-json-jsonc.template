[@lua -- output facet-validation members (D2): per element with restricted
	-- content/attributes, json_<name>::validate() throws std::runtime_error on a
	-- violation and returns true otherwise. Pattern facets (P3) are not enforced.
	local outbuf = stringBuffer:new()
	-- Emit checks for one expression `expr` of cpp type `ctype` against `facets`.
	local function cppChecks(expr, ctype, facets)
		local out = stringBuffer:new()
		local isStr = (ctype == ctype_char_p)
		local function fail()
			out:append('\t\tthrow std::runtime_error("facet violation");\n')
		end
		table.map(facets_checks(facets), function(_, c)
			if c.kind == 'range' and not isStr then
				local parts = {}
				if c.lo then parts[#parts + 1] = '(' .. expr .. ') >= ' .. c.lo end
				if c.hi then parts[#parts + 1] = '(' .. expr .. ') <= ' .. c.hi end
				out:append('\tif (!(' .. table.concat(parts, ' && ') .. '))\n')
				fail()
			elseif c.kind == 'length' and isStr then
				local n = '(' .. expr .. ').size()'
				local parts = {}
				if c.exact then parts[#parts + 1] = n .. ' == ' .. c.exact end
				if c.min then parts[#parts + 1] = n .. ' >= ' .. c.min end
				if c.max then parts[#parts + 1] = n .. ' <= ' .. c.max end
				out:append('\tif (!(' .. table.concat(parts, ' && ') .. '))\n')
				fail()
			elseif c.kind == 'enum' and not isStr then
				-- numeric enum: compare the parsed value directly
				local conds = {}
				table.map(c.values, function(_, v)
					conds[#conds + 1] = '(' .. expr .. ') == ' .. v
				end)
				out:append('\tif (!(' .. table.concat(conds, ' || ') .. '))\n')
				fail()
			elseif c.kind == 'enum' then
				-- string enum: switch on the seed-0 sdbm hash of the value.
				-- Group values by hash; a collision-free group emits a bare
				-- case, a colliding group strcmp-confirms before accepting.
				local byHash, order = sdbm_group(c.values)
				out:append('\tswitch (SDBMHash_(0, (' .. expr .. ').c_str())) {\n')
				table.map(order, function(_, h)
					local vs = byHash[h]
					if #vs == 1 then
						out:append('\tcase ' .. h .. 'u: break;\n')
					else
						-- hash collision: confirm the exact literal
						local ors = {}
						table.map(vs, function(_, v)
							ors[#ors + 1] = '(' .. expr .. ') == "' .. v .. '"'
						end)
						out:append('\tcase ' .. h .. 'u:\n')
						out:append('\t\tif (' .. table.concat(ors, ' || ') .. ') break;\n')
						out:append('\t\tthrow std::runtime_error("facet violation");\n')
					end
				end)
				out:append('\tdefault: throw std::runtime_error("facet violation");\n')
				out:append('\t}\n')
			end
		end)
		return out:str()
	end
	-- which elements carry facet restrictions
	local function nodeFacets(node)
		local emitted = {}
		if node.content.facets then
			local ct = cpp_narrowType(node.content.type, node.content.facets)
			emitted[#emitted + 1] =
				cppChecks(ct.buildVar('', 'Content'), ct, node.content.facets)
		end
		table.map(node.attributes, function(name, attr)
			if attr.facets then
				local at = cpp_narrowType(attr.type, attr.facets)
				emitted[#emitted + 1] =
