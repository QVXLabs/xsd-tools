/* Move-only RAII owner for a json_object*: json_object_put on destruction so
 * the manual refcount management of the C target becomes scope-bound. */
struct JsonRef {
	json_object* p_;
	JsonRef() : p_(nullptr) {}
	explicit JsonRef(json_object* p) : p_(p) {}
	~JsonRef() { if (p_) json_object_put(p_); }
	JsonRef(JsonRef&& o) : p_(o.p_) { o.p_ = nullptr; }
	JsonRef& operator=(JsonRef&& o) {
		if (this != &o) { reset(o.p_); o.p_ = nullptr; }
		return *this;
	}
	JsonRef(const JsonRef&) = delete;
	JsonRef& operator=(const JsonRef&) = delete;
	json_object* get() const { return p_; }
	json_object* release() { json_object* t = p_; p_ = nullptr; return t; }
	void reset(json_object* p = nullptr) {
		if (p_ && p_ != p) json_object_put(p_);
		p_ = p;
	}
};

typedef std::string json_buffer;

#endif /* JSON_COMMON_H */

