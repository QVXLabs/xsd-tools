[@lua --define python base64 type
	pythontype_base64 = {
		marshal = {
			attribute = function(wire, ident)
				return table.concat({
					"        if self._", ident, " is not None:\n",
					"            stream.write(' ", wire, "=\"' + base64.b64encode(self._", ident, ").decode('ascii') + '\"')\n",
				})
			end,
			content = function()
				return table.concat({
					"        if self.getContent():\n",
					"            stream.write(base64.b64encode(self.getContent()[0]).decode('ascii'))\n",
				})
			end,
		},
		unmarshal = {
			attribute = function(wire, ident)
				return table.concat({
					"        if \"", wire, "\" in attributes:\n",
					"            self._", ident, " = base64.b64decode(attributes[\"", wire, "\"].encode('ascii'))\n",
				})
			end,
			content = function()
				return table.concat({
					"        self._content = [base64.b64decode(content[0].encode('ascii'))] if content else []\n"
				})
			end
		},
		default = function(ident, value)
			return table.concat({"        self._", ident, " = base64.b64decode(", pyQuote(value), ".encode('ascii'))\n"})
		end,
		test = {
			assign = function()
				local ret = {
					"Q3yj/lYzNI0Fp0SrC8sctw==",
					"kpxzQiW1uLkFessP+5xZjQ==",
					"/kFxXF8edN6Dt3L99Y6aFQ==",
					"PceWThKB0OQoYk6O0nigSw==",
					"KDk10Nf+vS+JrzsYzRuDRw==" }
				return ret[math.random(1, 5)]
			end,
		},
	}
]