[@lua --define python list float type
	pythontype_listFloat = {
		marshal = {
			attribute = function(wire, ident)
				return table.concat({
					"        if self._", ident, " is not None:\n",
					"            stream.write(' ", wire, "=\"' + \" \".join([str(x) for x in self._", ident, "]) + '\"')\n",
				})
			end,
			content = function()
				return table.concat({
					"        stream.write(\" \".join([str(x) for x in self.getContent()]))\n"
				})
			end,
		},
		unmarshal = {
			attribute = function(wire, ident)
				return table.concat({
					"        if \"", wire, "\" in attributes:\n",
					"            self._", ident, " = [float(x) for x in attributes[\"", wire, "\"].split()]\n",
				})
			end,
			content = function()
				return table.concat({
					"        self._content = [float(x) for x in content[0].split()] if content else []\n"
				})
			end
		},
		default = function(ident, value)
			return table.concat({"        self._", ident, " = [float(x) for x in ", pyQuote(value), ".split()]\n"})
		end,
		test = {
			assign = function()
				return table.concat({
					tostring(math.random() * math.random(-127, 127)),
					tostring(math.random() * math.random(-127, 127)),
					tostring(math.random() * math.random(-127, 127))
				}, " ")
			end,
		},
	}
]