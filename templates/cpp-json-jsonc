/* Attach pElm under pParent[pKey]. Repeated (maxOccurs>1) elements accumulate
   into a JSON array so each sibling survives; scalars are set directly. */
void attach_(json_object* pParent, const char* pKey, json_object* pElm, bool isArray) {
	if (isArray) {
		json_object* pArr = nullptr;
		if (json_object_object_get_ex(pParent, pKey, &pArr)
			&& json_object_is_type(pArr, json_type_array)) {
			json_object_array_add(pArr, pElm);
		} else {
			pArr = json_object_new_array();
			json_object_array_add(pArr, pElm);
			json_object_object_add(pParent, pKey, pArr);
		}
	} else {
		json_object_object_add(pParent, pKey, pElm);
	}
}

