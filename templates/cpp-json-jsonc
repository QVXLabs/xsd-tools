			local contentType = cpp_narrowType(node.content.type, node.content.facets)
			outbuf:append('\tif (json_object_object_get_ex(pJson, "$", &pField)) {\n')
			outbuf:append('\t\t'..contentType.binding.unmarshal.statement('pField', contentType.buildVar(objName, 'Content')))
			outbuf:append('\t}\n')
		end
		-- recurse into child elements. Repeated children arrive as a JSON array;
		-- iterate it so every element is delivered (a lone scalar is tolerated).
		table.map(node.dependents, function(_, child)
			outbuf:append('\tif (json_object_object_get_ex(pJson, "'..child.name..'", &pField)) {\n')
			if isArrayNode(child) then
				outbuf:append('\t\tif (json_object_is_type(pField, json_type_array)) {\n')
				outbuf:append('\t\t\tsize_t n = json_object_array_length(pField);\n')
				outbuf:append('\t\t\tfor (size_t ndx = 0; ndx < n; ++ndx)\n')
				outbuf:append('\t\t\t\tunmarshalElm_'..child.ident..'_(marshaller, json_object_array_get_idx(pField, ndx), factory, pObj->eid_);\n')
				outbuf:append('\t\t} else {\n')
				outbuf:append('\t\t\tunmarshalElm_'..child.ident..'_(marshaller, pField, factory, pObj->eid_);\n')
				outbuf:append('\t\t}\n')
			else
				outbuf:append('\t\tunmarshalElm_'..child.ident..'_(marshaller, pField, factory, pObj->eid_);\n')
			end
			outbuf:append('\t}\n')
		end)
		-- validate (D2) gates only the notify; the object is freed by pObjOwner
		-- on scope exit regardless.
		outbuf:append('\tif (pObj->validate()) {\n')
		outbuf:append('\t\tif (marshaller.unmarshal_'..node.ident..') marshaller.unmarshal_'..node.ident..'(&marshaller, pObj, parentId);\n')
		outbuf:append('\t}\n')
		outbuf:append('}\n\n')
	end)
	return outbuf:str()
]
} /* namespace */

void json_unmarshal_ex(json_marshaller& marshaller, const json_buffer& buf, bool isDocEnd, const Factory& factory) {
	(void)isDocEnd;
	JsonRef root(json_tokener_parse(buf.c_str()));
	json_object* pField = nullptr;
	(void)pField;
	if (!root.get())
		throw std::runtime_error("json_unmarshal: failed to parse input document");
	{
[@lua -- dispatch root-level elements
	local outbuf = stringBuffer:new()
	table.map(schema.types[schema.root].dependents, function(_, child)
		outbuf:append('\t\tif (json_object_object_get_ex(root.get(), "'..child.name..'", &pField)) {\n')
		if isArrayNode(child) then
			outbuf:append('\t\t\tif (json_object_is_type(pField, json_type_array)) {\n')
			outbuf:append('\t\t\t\tsize_t n = json_object_array_length(pField);\n')
			outbuf:append('\t\t\t\tfor (size_t ndx = 0; ndx < n; ++ndx)\n')
			outbuf:append('\t\t\t\t\tunmarshalElm_'..child.ident..'_(marshaller, json_object_array_get_idx(pField, ndx), factory, 0);\n')
			outbuf:append('\t\t\t} else {\n')
			outbuf:append('\t\t\t\tunmarshalElm_'..child.ident..'_(marshaller, pField, factory, 0);\n')
			outbuf:append('\t\t\t}\n')
		else
			outbuf:append('\t\t\tunmarshalElm_'..child.ident..'_(marshaller, pField, factory, 0);\n')
		end
		outbuf:append('\t\t}\n')
	end)
	return outbuf:str()
]	}
}

void json_unmarshal(json_marshaller& marshaller, const json_buffer& buf, bool isDocEnd) {
	json_unmarshal_ex(marshaller, buf, isDocEnd, defaultFactory_());
}
