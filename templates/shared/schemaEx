[@lua -- add a dependency sort to the schema table
	--sort dependencies so that they are matched correctly
	local function topoSort(node)
		local depOrder = {}
		local visited = {}
		local function visit(node)
			-- key on node identity: distinct types may share a wire name, and
			-- recursion resolves several dependents to one node.
			if visited[node] then return end
			visited[node] = true
			-- deterministic child order so generated output is stable (E)
			local names = {}
			for k in pairs(node.dependents) do names[#names + 1] = k end
			table.sort(names)
			for _, k in ipairs(names) do visit(node.dependents[k]) end
			depOrder[#depOrder + 1] = node
		end
		visit(node)
		return depOrder
	end
	-- add function to schema table
	schema.sortDependencies = function()
		return topoSort(schema.types[schema.root])
	end
][@lua -- code-identifier assignment (A/B): wire names stay verbatim; each type
	-- and attribute gains a valid, de-collided `.ident`.

	-- Map any NCName to a valid identifier: every char outside [A-Za-z0-9_]
	-- becomes '_', a leading digit is prefixed (not dropped), empty maps to
	-- '_'. De-collide deterministically against `reserved` (a set of taken
	-- identifiers, seeded by callers with language keywords); the chosen
	-- identifier is marked taken so repeated calls stay distinct.
	local function sanitizeIdent(name, reserved)
		reserved = reserved or {}
		local ident = tostring(name):gsub('[^%w_]', '_')
		if ident:match('^%d') then ident = '_'..ident end
		if ident == '' then ident = '_' end
		local base, out, n = ident, ident, 0
		while reserved[out] do
			n = n + 1
			out = base..'_'..n
		end
		reserved[out] = true
		return out
	end
	-- exposed so targets can name additional identifiers (e.g. child-element
	-- struct fields) collision-free against their own reserved set.
	schema.sanitizeIdent = sanitizeIdent

	local function sortedKeys(tbl)
		local keys = {}
		for k in pairs(tbl or {}) do keys[#keys + 1] = k end
		table.sort(keys)
		return keys
	end

	-- Assign `.ident` across the model. `keywords` (optional) is a set of
	-- reserved identifiers/language keywords the target wants kept clear.
	-- Type identifiers are globally unique over schema.types; attribute
	-- identifiers are unique within their owning type's field namespace.
	local function assignIdents(keywords)
		keywords = keywords or {}
		local typeReserved = {}
		for kw in pairs(keywords) do typeReserved[kw] = true end
		local typeKeys = sortedKeys(schema.types)
		for _, k in ipairs(typeKeys) do
			schema.types[k].ident = sanitizeIdent(k, typeReserved)
		end
		for _, k in ipairs(typeKeys) do
			local t = schema.types[k]
			local fieldReserved = {}
			for kw in pairs(keywords) do fieldReserved[kw] = true end
			for _, an in ipairs(sortedKeys(t.attributes)) do
				t.attributes[an].ident = sanitizeIdent(an, fieldReserved)
			end
		end
		return schema
	end
	-- add function to schema table
	schema.c_safeNames = function(keywords)
		return assignIdents(keywords)
	end
	schema.python_safeNames = function(keywords)
		return assignIdents(keywords)
	end
][@lua -- find all unique types used in xsd
	schema.uniqueTypes = function()
		local ret = {}
		local seen = {}
		local function recurse(k, v)
			if seen[v] then return end
			seen[v] = true
			if next(v.content) then
				ret[v.content.type] = v.content.type
			end
			table.map(v.attributes, function(k,v)
				ret[v.type]= v.type
			end)
			table.map(v.dependents, recurse)
		end
		recurse(schema.root, schema.types[schema.root])
		return ret
	end
]