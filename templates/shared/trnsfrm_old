[@lua
function trnsfrm_oldFmt(tbl)
	local State = {
		Initialize = 0,
		Element = 1,
		Content = 2,
		AttributeNames = 3,
		AttributeType = 4
	}
	local StateName = {
		[0] = 'Initialize',
		[1] = 'Element',
		[2] = 'Content',
		[3] = 'AttribtueNames',
		[4] = 'AttributeType'
	}
	local function isBaseType(type)
		return (next(type.attributes) == nil and next(type.content) == nil)
	end
	local outTblRoot = {
		root = __SCHEMA_NAME__,
		types = {}
	}
	-- canonical, order-independent serialization of a facet sub-table: scalar
	-- facets as key=value, list facets (enumeration/pattern) as a sorted set.
	-- Folded into the type signature so two types that share structure but
	-- differ only in facets stay distinct (D2).
	local function facetSig_(f)
		if not f then return '' end
		local keys = {}
		for k in pairs(f) do keys[#keys + 1] = k end
		table.sort(keys)
		local parts = {}
		for _, k in ipairs(keys) do
			local v = f[k]
			if type(v) == 'table' then
				local items = {}
				for i = 1, #v do items[i] = tostring(v[i]) end
				table.sort(items)
				parts[#parts + 1] = k..'=['..table.concat(items, '|')..']'
			else
				parts[#parts + 1] = k..'='..tostring(v)
			end
		end
		return table.concat(parts, ',')
	end
	-- structural signature of a normalized type: content type+facets + sorted
	-- attribute name=type#facets pairs + sorted dependent name:sig. Order-
	-- independent and memoized per node so structurally-equal types hash
	-- identically, while facet-different types do not (D2).
	local sigOf_ = {}
	local inProgress_ = {}
	local function typeSig_(node)
		if sigOf_[node] then return sigOf_[node] end
		-- back-edge on a recursive type: the eager typeref resolution can make
		-- dependents point at an ancestor, so cap the walk with a stable marker.
		if inProgress_[node] then return '@rec' end
		inProgress_[node] = true
		local attrs = {}
		for an, av in pairs(node.attributes or {}) do
			attrs[#attrs + 1] =
				an..'='..(av.type or '')..'#'..facetSig_(av.facets)
		end
		table.sort(attrs)
		local deps = {}
		for dn, dv in pairs(node.dependents or {}) do
			deps[#deps + 1] = dn..':'..typeSig_(dv)
		end
		table.sort(deps)
		local sig = '{c='..((node.content and node.content.type) or '')
			..'|cf='..facetSig_(node.content and node.content.facets)
			..';a='..table.concat(attrs, ',')
			..';d='..table.concat(deps, ',')..'}'
		inProgress_[node] = nil
		sigOf_[node] = sig
		return sig
	end
	-- pick a flat-table key for a type: reuse the base name (or a prior
	-- suffix) when the structure matches a type already under that key, else
	-- allocate the next numeric suffix so distinct same-named types don't
	-- collapse into one struct (#11). This key is the code-identifier basis;
	-- the element's wire name is kept separately and never suffixed (A).
	local typeSigByName_ = {}
	local function uniqueTypeName_(base, node)
		local sig = typeSig_(node)
		local candidate, n = base, 0
		while true do
			if outTblRoot.types[candidate] == nil then
				typeSigByName_[candidate] = sig
				return candidate
			elseif typeSigByName_[candidate] == sig then
				return candidate
			end
			n = n + 1
			candidate = base..n
		end
	end
	-- normalized cardinality (C): min defaults to 1, max defaults to 1, the
	-- raw -1 sentinel becomes the string 'unbounded'.
	local function setOccurs_(outTbl, tbl)
		outTbl.minOccurs = (tbl.minOccurs ~= nil) and tbl.minOccurs or 1
		local mx = tbl.maxOccurs
		if mx == nil then outTbl.maxOccurs = 1
		elseif mx == -1 then outTbl.maxOccurs = 'unbounded'
		else outTbl.maxOccurs = mx end
	end
	local function trnsfrm_r(tbl, state, outTbl, scope)
		--dbgPrint(StateName[state])
		scope = scope or {}
		if state == State.Initialize then
			outTblRoot.types[__SCHEMA_NAME__] = {
				dependents={},
				content={},
				attributes={},
				name=__SCHEMA_NAME__
			}
			local rootScope = setmetatable(
				{ [__SCHEMA_NAME__] = outTblRoot.types[__SCHEMA_NAME__] },
				{ __index = scope })
			trnsfrm_r(tbl, State.Content, outTbl.types[__SCHEMA_NAME__],
				rootScope)
			return outTbl
		elseif state == State.Element then
			if nil == outTbl['dependents'] then
				outTbl['dependents'] = {}
			end
			if nil == outTbl['content'] then
				outTbl['content'] = {}
			end
			if nil == outTbl['attributes'] then
				outTbl['attributes'] = {}
			end
			-- carry cardinality onto the element/dependent node (C)
			setOccurs_(outTbl, tbl)
			for k, v in pairs(tbl) do
				if k == 'content' then
					trnsfrm_r(v, State.Content, outTbl, scope)
				elseif k == 'attributes' then
					trnsfrm_r(v, State.AttributeNames, outTbl, scope)
				end
			end
			return outTbl
		elseif state == State.Content then
			local Substate = {
				ContentNotFound = 0,
				ContentFound = 1
			}
			local substate = Substate.ContentNotFound
			for k, v in pairs(tbl) do
				if v.typeref then
					-- recursive reference: bind to the nearest lexical ancestor
					-- of this name (A/C). Scope is collision-safe where the flat
					-- registry is not; fall back to a deferred placeholder only
					-- if no ancestor matches. No setOccurs_ here on purpose: the
					-- ancestor is the same element declaration under this name, so
					-- it already carries this reference's minOccurs/maxOccurs (a
					-- name can't recur with different occurs in one content model).
					local target = scope[v.typeref]
					if target then
						outTbl.dependents[k] = target
					else
						outTbl.dependents[k] =
							{ name = k, __typeref = v.typeref }
					end
				elseif isBaseType(v) and substate == Substate.ContentNotFound then
					-- carry the leaf type's facets (D1) onto the normalized
					-- content so targets can emit validation/narrowing.
					-- namespace/qualified (E) ride along, nil when absent.
					outTbl['content'] = {
						type = k,
						facets = v.facets,
						namespace = v.namespace,
						qualified = v.qualified
					}
					substate = Substate.ContentFound
				elseif not isBaseType(v) then
					-- wire name is the element's real NCName (k) and is kept
					-- verbatim (A); the disambiguated registry key is the code-
					-- identifier basis, resolved to `.ident` in schemaEx.
					local child = { name = k }
					-- register before descending so a deeper recursive ref to
					-- this name resolves to this very node.
					local childScope = setmetatable(
						{ [k] = child }, { __index = scope })
					trnsfrm_r(v, State.Element, child, childScope)
					local key = uniqueTypeName_(k, child)
					child.regkey = key
					-- carry the element/type annotation (#4), nil when absent
					child.documentation = v.documentation
					outTbl.dependents[k] = child
					outTblRoot.types[key] = child
				end
			end
			return outTbl
		elseif state == State.AttributeNames then
			for k, v in pairs(tbl) do
				outTbl.attributes[k] = { name = k }
				trnsfrm_r(v, State.AttributeType, outTbl.attributes[k], scope)
			end
			return outTbl
		elseif state == State.AttributeType then
			attribName, attribDef = next(tbl)
			if nil ~= attribName then
				outTbl.type = attribName
				-- carry the attribute's restriction facets up for validation
				outTbl.facets = attribDef.facets
				-- namespace/qualified (E) + documentation (#4) ride along, nil
				-- when absent
				outTbl.namespace = attribDef.namespace
				outTbl.qualified = attribDef.qualified
				outTbl.documentation = attribDef.documentation
				-- use/default/fixed gate optionality: an optional attribute with
				-- neither default nor fixed has no value when absent.
				outTbl.use = attribDef.use
				if nil ~= attribDef.default then
					outTbl.default = attribDef.default
				end
				if nil ~= attribDef.fixed then
					outTbl.fixed = attribDef.fixed
				end
			end
			return outTbl
		end
	end
	local result = trnsfrm_r(tbl, State.Initialize, outTblRoot)
	-- second pass: resolve any deferred recursive placeholder by wire name
	-- against the type that carries it, kept only as a fallback for references
	-- the lexical scope did not cover.
	local byWire = {}
	for _, t in pairs(result.types) do byWire[t.name] = t end
	for _, t in pairs(result.types) do
		for dn, dv in pairs(t.dependents) do
			if dv.__typeref and byWire[dv.__typeref] then
				t.dependents[dn] = byWire[dv.__typeref]
			end
		end
	end
	return result
end
]