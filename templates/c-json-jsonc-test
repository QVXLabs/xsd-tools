[@lua --include and transform old format
	include 'shared/trnsfrm_old'
	schema = trnsfrm_oldFmt(schema)
][@lua --include any shared 'helper' templates
	return include 'shared/schemaEx'
][@lua --include facet helpers + xsd to c type mapping
	include 'shared/facets'
	return include 'includes/c-json-jsonc/c_type_info'
][@lua --generate helper globals
	schema = schema.c_safeNames(c_keywords)
	rootIdent = schema.types[schema.root].ident
	function isArrayNode(n)
		local mx = n.maxOccurs
		return mx == 'unbounded' or (type(mx) == 'number' and mx > 1)
	end
	-- rewire dependents to their registered representatives (see main template)
	canonicalizeDeps(schema, isArrayNode)
	uniqueXSDTypes = schema.uniqueTypes()
	uniqueCTypes = {}
	table.map(uniqueXSDTypes, function(_, v)
		-- skip non-builtin names (see main template)
		local ctype = c_type_info[v]
		if ctype then
			uniqueCTypes[ctype] = ctype
			if 'c_list' == ctype.type then
				local baseType = ctype.baseType()
				uniqueCTypes[baseType] = baseType
			end
		end
	end)
	typeSansRoot = table.filter(schema.types, function(k,v) return v.name ~= schema.root and v or nil end)
][@lua -- create friendly root schema name
	schemaName = schema.types[schema.root].name:gsub("_xsd$", "")
]
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <assert.h>
#include "json_[@lua return schemaName].h"

[@lua -- output test data
	local outbuf = stringBuffer:new()
	local listTypes = table.filter(uniqueCTypes, function(_,v) return 'c_list' == v.type and v or nil end)
	local listTypeVarMap = {}
	local ndx = 1
	table.map(listTypes, function(_,v)
		listTypeVarMap[v] = 'list'..ndx
		ndx = ndx + 1
	end)
	table.map(listTypes, function(_,v)
		outbuf:append(v.test.subDef(listTypeVarMap[v]))
	end)
	local ID = 1
	table.map(typeSansRoot, function(_, node)
		-- eid_ is emitted only for nodes with dependents or empty leaves
		local hasMembers = next(node.attributes) or next(node.content)
		valTbl = (next(node.dependents) or not hasMembers)
			and {'.eid_ = '..tostring(ID)} or {}
		local prcssType = function(ncname, xsdType)
			local c_type = c_narrowCType(xsdType.type, xsdType.facets)
			-- attributes address their .ident member; content uses "Content"
			local member = xsdType.ident or ncname
			if "c_list" == c_type.type then
				local cVarName = listTypeVarMap[c_type]
				table.insert(valTbl, c_type.buildVar('.',member)..' = '..c_type.test.assign(cVarName))
			else
				table.insert(valTbl, c_type.buildVar('.',member)..' = '..c_type.test.assign(xsdType.facets))
			end
		end
		table.map(node.attributes, prcssType)
		if next(node.content) then
			prcssType("Content", node.content)
		end
		outbuf:append(table.concat({
			"static const json_", node.ident, " ", node.ident, "Tst = {", table.concat(valTbl, ','),"};\n",
		}));
		ID = ID + 1
	end)
	return outbuf:str()
]

static void* reallocCb(struct json_marshaller* pMarshaller, void* pMem, size_t size) {
	(void)pMarshaller;
	if (0 == size) { free(pMem); return NULL; }
	return realloc(pMem, size);
}

[@lua -- output unmarshal callbacks (assert round-tripped fields match)
	local outbuf = stringBuffer:new()
	table.map(typeSansRoot, function(_, node)
		outbuf:append(table.concat({
			"static void unmarshal_", node.ident, "(struct json_marshaller* pMarshaller, const json_", node.ident, "* pObj, uint32_t parent) {\n",
			"\t(void)pMarshaller;\n",
			"\t(void)parent;\n",
			"\t(void)pObj;\n",
		}))
		local prcssType = function(ncname, xsdtype)
			local c_type = c_narrowCType(xsdtype.type, xsdtype.facets)
			local member = xsdtype.ident or ncname
			outbuf:append(c_type.test.assert(c_type.buildVar('pObj->', member), c_type.buildVar(node.ident..'Tst'..'.', member)))
		end
		table.map(node.attributes, prcssType)
		if next(node.content) then
			prcssType("Content", node.content)
		end
		outbuf:append("}\n")
	end)
	return outbuf:str()
]

/* Exercise the overridable factory triple: wrappers delegate to the defaults
 * but count alloc/construct/destroy so we can assert the path is taken and
 * balanced. */
static int g_allocCnt = 0;
static int g_constructCnt = 0;
static int g_destroyCnt = 0;

[@lua -- per-element factory-override wrappers + a custom factories table
	local outbuf = stringBuffer:new()
	local dft = 'json_'..schemaName..'_default_factories()'
	table.map(typeSansRoot, function(_, node)
		outbuf:append(table.concat({
			'static json_', node.ident, '* ovr_', node.ident, 'Allocator(struct json_marshaller* pM) {\n',
			'\t++g_allocCnt;\n',
			'\treturn ', dft, '->', node.ident, 'Allocator(pM);\n',
			'}\n',
			'static void ovr_', node.ident, 'Constructor(struct json_marshaller* pM, json_', node.ident, '* pObj) {\n',
			'\t(void)pM; (void)pObj; ++g_constructCnt;\n',
			'}\n',
			'static json_', node.ident, '* ovr_', node.ident, 'Destructor(struct json_marshaller* pM, json_', node.ident, '* pObj) {\n',
			'\t++g_destroyCnt;\n',
			'\treturn ', dft, '->', node.ident, 'Destructor(pM, pObj);\n',
			'}\n',
		}))
	end)
	outbuf:append('static const json_'..schemaName..'_factories g_overrideFactories = {\n')
	local fnLst = table.filter(typeSansRoot, function(_, node)
		return table.concat({
			'\t.', node.ident, 'Allocator = ovr_', node.ident, 'Allocator,\n',
			'\t.', node.ident, 'Constructor = ovr_', node.ident, 'Constructor,\n',
			'\t.', node.ident, 'Destructor = ovr_', node.ident, 'Destructor',
		})
	end)
	outbuf:append(table.concat(fnLst, ',\n'))
	outbuf:append('\n};\n')
	return outbuf:str()
]

int main(void) {
	json_buffer output;
	json_marshaller mrshllr = {
		.realloc = reallocCb,
[@lua --output unmarshal function assignments
	local tbl = {}
	table.map(typeSansRoot, function(_, node)
		table.insert(tbl, "\t\t.unmarshal_"..node.ident.." = unmarshal_"..node.ident)
	end)
	return table.concat(tbl, ",\n")
]
	};
	/* test marshalling */
[@lua --output marshalling start + statements
	local outbuf = stringBuffer:new()
	local rootHasDeps = next(schema.types[schema.root].dependents)
	-- the entry returns the document's callback struct (by value)
	if rootHasDeps then
		outbuf:append('\tjson_marshal_'..rootIdent
			..' ret0 = json_marshal(&mrshllr);\n')
	else
		outbuf:append('\tjson_marshal(&mrshllr);\n')
	end
	-- Drive the fluent marshaller depth-first. A recursive type is its own
	-- ancestor; cap re-entry at twice per active path so the self/mutual
	-- recursion edge is exercised while the synthesised document stays finite.
	local seqId = 0
	local onPath = {}
	local function marshalChildren(parentVar, node)
		table.map(node.dependents, function(_, child)
			if next(child.dependents) then
				if (onPath[child.ident] or 0) >= 2 then return end
				onPath[child.ident] = (onPath[child.ident] or 0) + 1
				seqId = seqId + 1
				local v = 'ret'..seqId
				outbuf:append('\tjson_marshal_'..child.ident..' '..v..' = '
					..parentVar..'.marshal_'..child.ident
					..'(&mrshllr, &'..child.ident..'Tst, '..parentVar..'.pSelf);\n')
				marshalChildren(v, child)
				onPath[child.ident] = onPath[child.ident] - 1
			else
				outbuf:append('\t'..parentVar..'.marshal_'..child.ident
					..'(&mrshllr, &'..child.ident..'Tst, '..parentVar..'.pSelf);\n')
			end
		end)
	end
	if rootHasDeps then
		marshalChildren('ret0', schema.types[schema.root])
	end
	return outbuf:str()
]	output = json_marshal_flush(&mrshllr, 1);
	/* test unmarshalling through the default factory table */
	json_unmarshal_ex(&mrshllr, &output, 1, json_[@lua return schemaName]_default_factories());
	/* re-run through the override table to exercise the factory triple */
	json_unmarshal_ex(&mrshllr, &output, 1, &g_overrideFactories);
[@lua -- assert the override path ran (skip when schema has no elements)
	if next(typeSansRoot) then
		return table.concat({
			'\tassert(g_allocCnt > 0);\n',
			'\tassert(g_allocCnt == g_constructCnt);\n',
			'\tassert(g_allocCnt == g_destroyCnt);\n',
		})
	end
	return ''
]
	/* clean up */
	output.pBuf_ = realloc(output.pBuf_, 0);
	return 0;
}
