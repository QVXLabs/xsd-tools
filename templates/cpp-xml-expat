			-- a unique_ptr<T> optional attribute is emitted only when present,
			-- so an absent optional round-trips as absent (not fabricated).
			local nullable = attrNullable(a)
			local ref = nullable and ('(*obj.'..name..'_)')
				or ('obj.'..name..'_')
			-- single-char closer appends as a char (no strlen of a 1-char string)
			local emit = '\tout_ += '..cppStr(' '..nsQualify(name)..'="')
				..'; out_ += '..ct.marshal(ref)..'; out_ += \'"\';\n'
			if nullable then
				outbuf:append('\tif (obj.'..name..'_) {\n\t'..emit..'\t}\n')
			else
				outbuf:append(emit)
			end
		end)
		if hasAttrs then
			outbuf:append('\tout_ += \'>\';\n')
		end
		if next(node.content) then
			local ct = cpp_narrowCType(node.content.type, node.content.facets)
			outbuf:append('\tout_ += '..ct.marshal('obj.content_')..';\n')
		end
		outbuf:append('\tMarshalRec rec; rec.id = '..elemId[node.name]
			..'; rec.closeTag = '..cppStr('</'..nsQualify(node.name)..'>')
			..';\n')
		outbuf:append('\tmarshalStk_.push_back(std::move(rec));\n')
		outbuf:append('}\n')
	end)
	return outbuf:str()
]
std::string
Marshaller::flush(bool isDocEnd) {
	if (isDocEnd) closeToParents_({0});
	std::string ret;
	ret.swap(out_);
	return ret;
}

/* expat static thunks -> member handlers (the load-bearing C-ABI bridge).
   A C++ exception must not unwind through expat's C frames, so each thunk
   catches, stashes it on the marshaller, and stops the parser; unmarshal()
   rethrows once control is back in C++. */
void XMLCALL
Marshaller::startThunk_(void* userData, const XML_Char* name,
                        const XML_Char** attrs) {
	Marshaller* m = static_cast<Marshaller*>(userData);
	try { m->onStart(name, attrs); }
	catch (...) { m->pending_ = std::current_exception();
		XML_StopParser(m->parser_, XML_FALSE); }
}
void XMLCALL
Marshaller::endThunk_(void* userData, const XML_Char* name) {
	(void)name;
	Marshaller* m = static_cast<Marshaller*>(userData);
	try { m->onEnd(); }
	catch (...) { m->pending_ = std::current_exception();
		XML_StopParser(m->parser_, XML_FALSE); }
}
void XMLCALL
Marshaller::charsThunk_(void* userData, const XML_Char* s,
                        int len) {
	Marshaller* m = static_cast<Marshaller*>(userData);
	try { m->onChars(s, len); }
	catch (...) { m->pending_ = std::current_exception();
		XML_StopParser(m->parser_, XML_FALSE); }
}

[@lua -- per-element unmarshal(): single-pass hash-parse of the raw attrs, then
	-- build via the factory (subtype injection). Out-of-line so Factory is whole.
	local function indentLines(s, pre)
		return (s:gsub('[^\n]+', function(l) return pre..l end))
	end
	local function stmt(s) return (s:gsub('%s*$', '')) end
	local out = stringBuffer:new()
	table.map(depOrderSansRoot, function(_, node)
		local attrs = nodeAttrs(node)
		out:append('std::unique_ptr<'..node.name..'>\n'..node.name
			..'::unmarshal(const Factory& f, const char* tagName,'
			..' const XML_Char** attrs) {\n')
		if #attrs > 0 then
			out:append('\t(void)tagName;\n')
			table.map(attrs, function(_, m)
				local ct = cpp_narrowCType(m.a.type, m.a.facets)
				if m.nullable then
					out:append('\tstd::unique_ptr<'..m.ctype..'> a_'..m.name
						..';\n')
				else
					local dv = m.a.default or m.a.fixed
					out:append('\t'..m.ctype..' a_'..m.name..' = '
						..(dv and ct.defaultExpr(dv) or '{}')..';\n')
				end
			end)
			out:append('\tfor (const XML_Char** a = attrs; *a; a += 2) {\n')
			out:append('\t\tconst char* an = localName_(a[0]);\n')
			out:append(indentLines(cppHashSwitch('an', attrs,
				function(m) return m.name end,
				function(m)
					local ct = cpp_narrowCType(m.a.type, m.a.facets)
					local src = ct.cstrSrc and 'a[1]' or 'av'
					local pre = ct.cstrSrc and ''
						or '\t\tconst std::string av(a[1]);\n'
					local dst = 'a_'..m.name
					if ct.parseExpr then
						local v = ct.parseExpr(src)
						return pre..'\t\t'..(m.nullable
							and (dst..'.reset(new '..m.ctype..'('..v..'));')
							or (dst..' = '..v..';'))..'\n'
					end
					if m.nullable then
						return pre..'\t\t'..m.ctype..' _pv{}; '..stmt(ct.parse(src,
							'_pv'))..' '..dst..'.reset(new '..m.ctype
							..'(std::move(_pv)));\n'
					end
					return pre..'\t\t'..stmt(ct.parse(src, dst))..'\n'
				end), '\t'))
			out:append('\t}\n')
			local args = {}
			table.map(attrs, function(_, m)
				args[#args + 1] = 'std::move(a_'..m.name..')'
			end)
			out:append('\treturn f.create_'..node.name..'('
				..table.concat(args, ', ')..');\n')
		else
			out:append('\t(void)tagName; (void)attrs;\n')
			out:append('\treturn f.create_'..node.name..'();\n')
		end
		out:append('}\n')
	end)
	return out:str()
]
void
Marshaller::onStart(const char* tagName, const XML_Char** attrs) {
	const char* local = localName_(tagName);
	ParseRec rec;
	const Factory* f = factory_ ? factory_ : &defaultFactory_();
[@lua -- dispatch the element name to its static unmarshal, which parses the
	-- attrs and builds via the factory.
	local function elemBody(node)
		local b = stringBuffer:new()
		b:append('\t\trec.elem = '..node.name
			..'::unmarshal(*f, tagName, attrs);\n')
		b:append('\t\trec.notify = [this](Element* e) { on_'..node.name
			..'(static_cast<'..node.name..'&>(*e)); };\n')
		-- buffer char data only when the element has text content
		if next(node.content) then
			b:append('\t\trec.wantsContent = true;\n')
		end
		return b:str()
	end
	return cppHashSwitch('local', depOrderSansRoot,
		function(node) return node.name end, elemBody)
]	parseStk_.push_back(std::move(rec));
}

void
Marshaller::onChars(const char* s, int len) {
	/* skip char data for container elements (no text content to parse) */
	if (!parseStk_.empty() && parseStk_.back().wantsContent)
		parseStk_.back().content.append(s, len);
}

void
Marshaller::onEnd() {
	if (parseStk_.empty()) return;
	ParseRec rec = std::move(parseStk_.back());
	parseStk_.pop_back();
	if (rec.elem) {
		rec.elem->setContent(rec.content);
		rec.elem->validate();
		if (rec.notify) rec.notify(rec.elem.get());
	}
}

void
Marshaller::unmarshal(const char* data, std::size_t len, bool isDocEnd) {
	if (!parser_) {
		parser_ = XML_ParserCreateNS("utf-8", ':');
		XML_SetUserData(parser_, this);
		XML_SetElementHandler(parser_, startThunk_, endThunk_);
		XML_SetCharacterDataHandler(parser_, charsThunk_);
	}
	XML_Parse(parser_, data, static_cast<int>(len), isDocEnd ? 1 : 0);
	if (isDocEnd) {
		XML_ParserFree(parser_);
		parser_ = nullptr;
	}
	if (pending_) {
		std::exception_ptr e = pending_;
		pending_ = nullptr;
		std::rethrow_exception(e);
	}
}

