[@lua --include and transform old format
	include 'shared/trnsfrm_old'
	schema = trnsfrm_oldFmt(schema)
][@lua --include any shared 'helper' templates
	return include 'shared/schemaEx'
][@lua --include Java/StAX type info
	include 'shared/facets'
	include 'includes/java-xml-stax/java_type_info'
][@lua --c-safe names
	javaPKGName = "com.mobitv.app"
	include 'includes/java-xml-stax/java_safe_name'
	schema = schema.c_safeNames(JAVA_KEYWORDS)
	guardFrameworkNames(schema)
]package com.mobitv.app;

/* Round-trip driver: build a sample tree, marshal it to XML via StAX, unmarshal
 * back through the overridable Factory, re-marshal, and print true/false per
 * top-level root element (the harness greps stdout for "false"). */
public class RunTest {

[@lua -- emit a builder method per complex type
	local outbuf = stringBuffer:new()
	local depOrder = schema.sortDependencies()
	-- fill orphan idents + collapse duplicates (see binding template)
	local depOrderSansRoot = normalizeDepList(schema, depOrder)
	-- A recursive type's builder calls itself (directly or mutually); cap
	-- re-entry at twice per active path with a per-type static counter so the
	-- recursion edge is exercised while the synthesised tree stays finite.
	table.map(depOrderSansRoot, function(_, node)
		if next(node.dependents) then
			outbuf:append("\tstatic int _"..node.ident.."_d = 0;\n")
		end
	end)
	outbuf:append("\n")
	-- Facet-aware test value: prefer a facet-satisfying sample so the value
	-- passes the emitted validation; fall back to the type's random gen.
	local function sampleFor(ti, facets)
		if facets then
			local s = (ti.jtype == "Integer" or ti.jtype == "Long")
				and facets_sampleInt(facets) or facets_sampleString(facets)
			if s then return s end
		end
		return ti.test.assign()
	end
	-- D2b: narrowed boxed type + primitive cast for numeric facet ranges,
	-- mirroring the binding so builder temporaries match the setter signature.
	local javaSigned = {
		Byte    = {box = "Byte",    prim = "byte"},
		Short   = {box = "Short",   prim = "short"},
		Integer = {box = "Integer", prim = "int"},
		Long    = {box = "Long",    prim = "long"},
	}
	local function javaNumType(ti, facets)
		if ti.jtype ~= "Integer" and ti.jtype ~= "Long" then return nil end
		local box = facets_narrowestSigned(facets)
		return box and javaSigned[box]
	end
	-- Emit a `<box> tmp = ...;` assignment matching the (possibly narrowed)
	-- field type, then return it. Narrowed numerics use a primitive cast so
	-- both int- and long-sourced samples assign cleanly.
	local function assignTmp(ti, facets)
		local nw = javaNumType(ti, facets)
		if nw then
			return table.concat({
				"\t\t\t", nw.box, " tmp = (", nw.prim, ") ",
				sampleFor(ti, facets), ";\n",
			})
		end
		local assign = ti.default("__T__", sampleFor(ti, facets))
		return "\t\t\t" .. ti.jtype .. " tmp;\n"
			.. assign:gsub("_+__T__", "tmp")
	end
	table.map(depOrderSansRoot, function(_, node)
		local hasContent = next(node.content) ~= nil
		local jn = node.ident
		outbuf:append(table.concat({
			"\tstatic ", jn, " build_", node.ident, "() {\n",
			"\t\t", jn, " e = new ", jn, "();\n",
		}))
		table.map(node.attributes, function(attribName, attribute)
			local ti = java_type_info[attribute.type]
			outbuf:append(table.concat({
				"\t\t{\n",
				assignTmp(ti, attribute.facets),
				"\t\t\te.set_", attribute.ident, "(tmp);\n",
				"\t\t}\n",
			}))
		end)
		if hasContent then
			local ti = java_type_info[node.content.type]
			outbuf:append(table.concat({
				"\t\t{\n",
				assignTmp(ti, node.content.facets),
				"\t\t\te.set_text(tmp);\n",
				"\t\t}\n",
			}))
		end
		table.map(node.dependents, function(depName, dep)
			if next(dep.dependents) then
				-- recursion-capable child: guard with its re-entry counter
				outbuf:append(table.concat({
					"\t\tif (_", dep.ident, "_d < 2) {\n",
					"\t\t\t_", dep.ident, "_d++;\n",
					"\t\t\te.children().add(build_", dep.ident, "());\n",
					"\t\t\t_", dep.ident, "_d--;\n",
					"\t\t}\n",
				}))
			else
				outbuf:append(table.concat({
					"\t\te.children().add(build_", dep.ident, "());\n",
				}))
			end
		end)
		outbuf:append("\t\treturn e;\n\t}\n\n")
	end)
	return outbuf:str()
]
	public static void main(String[] args) throws Exception {
		Document doc = new Document();
[@lua -- one round-trip per top-level root element
	local outbuf = stringBuffer:new()
	table.map(schema.types[schema.root].dependents, function(name, node)
		outbuf:append(table.concat({
			"\t\t{\n",
			"\t\t\tElement root = build_", node.ident, "();\n",
			"\t\t\tString s1 = doc.marshal(root);\n",
			"\t\t\tElement back = doc.unmarshal(s1);\n",
			"\t\t\tString s2 = doc.marshal(back);\n",
			"\t\t\tSystem.out.println(s1.equals(s2));\n",
			"\t\t}\n",
		}))
	end)
	return outbuf:str()
]	}
}
