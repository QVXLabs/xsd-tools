				emitted[#emitted + 1] =
					cChecks(at.buildVar('pObj->', attr.ident), at, attr.facets)
			end
		end)
		local body = table.concat(emitted)
		return (#body > 0) and body or nil
	end
	local validated = {}
	table.map(depOrderSansRoot, function(_, node)
		local body = nodeFacets(node)
		if body then
			validated[node.ident] = true
			outbuf:append(table.concat({
				'static int validate_', node.ident, '_(const json_', node.ident, '* pObj) {\n',
				body,
				'\treturn 0;\n}\n\n',
			}))
		end
	end)
	table.map(depOrderSansRoot, function(_, node)
		outbuf:append(table.concat({
			'static void unmarshalElm_', node.ident, '_(json_marshaller* pMarshaller, struct json_object* pJson, const json_', schemaName, '_factories* pFactories, uint32_t parentId);\n',
		}))
	end)
	outbuf:append('\n')
	table.map(depOrderSansRoot, function(_, node)
		outbuf:append(table.concat({
			'static void unmarshalElm_', node.ident, '_(json_marshaller* pMarshaller, struct json_object* pJson, const json_', schemaName, '_factories* pFactories, uint32_t parentId) {\n',
			'\tstruct json_object* pField;\n',
			'\tjson_', node.ident, '* pObj = AllocateElement(', node.ident, ', pMarshaller, pFactories);\n',
			'\tConstructElement(', node.ident, ', pObj, pMarshaller, pFactories);\n',
			'\tJSON_UNUSED_ARG(pField);\n',
		}))
		-- defaults: build the value as a json string (json-c coerces it to the
		-- target scalar); json_object_new_string escapes on output, cEscape keeps
		-- the C source literal valid.
		local objName = 'pObj->'
		table.map(node.attributes, function(name, attrib)
			if attrib.default then
				local attribType = c_narrowCType(attrib.type, attrib.facets)
				outbuf:append(table.concat({
					'\t{ struct json_object* pDef = json_object_new_string("', cEscape(attrib.default), '"); ',
					attribType.binding.unmarshal.statement('pDef', attribType.buildVar(objName, attrib.ident)),
					' json_object_put(pDef); }\n',
				}))
			end
		end)
		-- read attributes (verbatim wire key -> ident member)
		table.map(node.attributes, function(name, attrib)
			local attribType = c_narrowCType(attrib.type, attrib.facets)
			outbuf:append(table.concat({
				'\tif (json_object_object_get_ex(pJson, "', name, '", &pField)) {\n',
				'\t\t', attribType.binding.unmarshal.statement('pField', attribType.buildVar(objName, attrib.ident)),
				'\t}\n',
			}))
		end)
		-- read content
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			outbuf:append(table.concat({
				'\tif (json_object_object_get_ex(pJson, "$", &pField)) {\n',
				'\t\t', contentType.binding.unmarshal.statement('pField', contentType.buildVar(objName, 'Content')),
				'\t}\n',
			}))
		end
		-- recurse into child elements. Repeated children arrive as a JSON array;
		-- iterate it so every element is delivered (a lone scalar is tolerated).
		table.map(node.dependents, function(_, child)
			if isArrayNode(child) then
				outbuf:append(table.concat({
					'\tif (json_object_object_get_ex(pJson, "', child.name, '", &pField)) {\n',
					'\t\tif (json_object_is_type(pField, json_type_array)) {\n',
					'\t\t\tsize_t ndx, n = json_object_array_length(pField);\n',
					'\t\t\tfor (ndx = 0; ndx < n; ++ndx)\n',
					'\t\t\t\tunmarshalElm_', child.ident, '_(pMarshaller, json_object_array_get_idx(pField, ndx), pFactories, pObj->eid_);\n',
					'\t\t} else {\n',
					'\t\t\tunmarshalElm_', child.ident, '_(pMarshaller, pField, pFactories, pObj->eid_);\n',
					'\t\t}\n',
					'\t}\n',
				}))
			else
				outbuf:append(table.concat({
					'\tif (json_object_object_get_ex(pJson, "', child.name, '", &pField)) {\n',
					'\t\tunmarshalElm_', child.ident, '_(pMarshaller, pField, pFactories, pObj->eid_);\n',
					'\t}\n',
				}))
			end
		end)
		-- notify + destroy attributes/content. The validation guard (D2) wraps
		-- only the notify in braces so the destroy/realloc below always run.
		if validated[node.ident] then
			outbuf:append(table.concat({
				'\tif (0 == validate_', node.ident, '_(pObj)) {\n',
				'\t\tpMarshaller->unmarshal_', node.ident, '(pMarshaller, pObj, parentId);\n',
				'\t}\n',
			}))
		else
			outbuf:append('\tpMarshaller->unmarshal_'..node.ident..'(pMarshaller, pObj, parentId);\n')
		end
		table.map(node.attributes, function(name, attrib)
			local attribType = c_narrowCType(attrib.type, attrib.facets)
			outbuf:append(table.concat({
				'\t', attribType.delete.statement(attribType.buildVar(objName, attrib.ident)),
			}))
		end)
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			outbuf:append(table.concat({
				'\t', contentType.delete.statement(contentType.buildVar(objName, 'Content')),
			}))
		end
		outbuf:append('\tpObj = DestroyElement('..node.ident..', pObj, pMarshaller, pFactories);\n')
		outbuf:append('}\n\n')
	end)
	return outbuf:str()
]
