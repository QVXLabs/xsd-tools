][@lua --assign python-safe idents (wire names stay verbatim) & sort deps
	-- keywords that would be SyntaxErrors as class/method/member names
	pythonKeywords = {}
	for _, k in ipairs({'False','None','True','and','as','assert','async',
		'await','break','class','continue','def','del','elif','else',
		'except','finally','for','from','global','if','import','in','is',
		'lambda','nonlocal','not','or','pass','raise','return','try','while',
		'with','yield'}) do pythonKeywords[k] = true end
	schema = schema.python_safeNames(pythonKeywords)
	-- code identifier for a node: idents live on the type-registry entry, so
	-- resolve via regkey (structurally-identical elements share one).
	function pyIdent(node)
		local reg = schema.types[node.regkey]
		return (reg and reg.ident) or node.ident
	end
	depOrder = schema.sortDependencies()
	depOrderSansRoot = table.filter(depOrder, function(k,v) return v.name ~= schema.root and v or nil end)
	-- de-dup to one registry node per type so a shared-structure element is not
	-- emitted as two identical classes (would also miss idents on the copy).
	local _seenReg, _uniqTypes = {}, {}
	table.map(depOrderSansRoot, function(_, node)
		local reg = schema.types[node.regkey] or node
		if not _seenReg[reg] then
			_seenReg[reg] = true
			_uniqTypes[#_uniqTypes + 1] = reg
		end
	end)
	depOrderSansRoot = _uniqTypes
	-- gate binary-codec imports on actual type usage
	local usedTypes = schema.uniqueTypes()
	usesBase64 = usedTypes['base64Binary'] or usedTypes['list(base64Binary)']
	usesHex = usedTypes['hexBinary'] or usedTypes['list(hexBinary)']
