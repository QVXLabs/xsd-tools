					'\tcstr_appendN_(pMarshaller, pOutStr, ', cLit('"'), ');\n',
				}))
			end)
			-- output end of start tag
			outbuf:append('\tcstr_appendN_(pMarshaller, pOutStr, ">", 1);\n')
		end
		-- output content
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			outbuf:append(table.concat({
				'\t', contentType.binding.marshal.statement('pOutStr', contentType.buildVar('pObj->','Content'))
			}))
		end
		-- output function end code
		outbuf:append('\tmrshllElmStack_push_(pMarshaller, &pMarshaller->mrshllElmStk_, elemRec);\n')
		-- output extra function end code if element has dependents
		if next(node.dependents) then
			outbuf:append('\treturn retFuncs;\n')
		end
		outbuf:append('}\n')
	end)
	return outbuf:str()
]
[@lua -- output fist part of marshal function
	if next(schema.types[schema.root].dependents) then
		local depFncLst = table.filter(schema.types[schema.root].dependents, function(k,v) 
			return table.concat({
				'.marshal_', k, ' = ', 'marshal_', k, '_'
			})
		end)
		depFncLst =  table.concat(depFncLst,', ')
		return table.concat({
			'xml_marshal_', schema.root,'\nxml_marshal(xml_marshaller* pMarshaller) {\n',
			'\tconst xml_mrshllElmRec elemRec = {', hashU(schema.root), ', 0};\n',
			'\txml_marshal_', schema.root, '  retFuncs= {', depFncLst, '};\n',
		})
	else
		return table.concat({
			'void\nxml_marshal(xml_marshaller* pMarshaller) {\n',
			'\tconst xml_mrshllElmRec elemRec = {', hashU(schema.root), ', 0};\n',
		})
	end
]	xml_cstr* pOutStr = &pMarshaller->mrshllBuf_;
	buffer_init_(pMarshaller, &pMarshaller->mrshllElmStk_);
	cstr_init_(pMarshaller, &pMarshaller->mrshllBuf_);
	mrshllElmStack_push_(pMarshaller, &pMarshaller->mrshllElmStk_, elemRec);
	cstr_appendN_(pMarshaller, pOutStr, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>", 38);
[@lua if next(schema.types[schema.root].dependents) then return "\treturn retFuncs;" end]
}

xml_buffer
xml_marshal_flush(xml_marshaller* pMarshaller, int isDocEnd) {
	static const xml_buffer newBuf = { NULL, 0, 0 };
	xml_buffer retBuf = pMarshaller->mrshllBuf_;
	if (isDocEnd) {
		marshal_adjustElmStk_(pMarshaller,0);
		buffer_destroy_(pMarshaller, &pMarshaller->mrshllElmStk_);
		retBuf = pMarshaller->mrshllBuf_;
		pMarshaller->mrshllBuf_ = newBuf;
	} else {
		pMarshaller->mrshllBuf_ = newBuf;
		buffer_init_(pMarshaller, &pMarshaller->mrshllBuf_);
	}
	return retBuf;
}

static void*
expatMalloc_(size_t size) {
	return gtlsspMarshler->realloc(gtlsspMarshler, NULL, size);
}

static void*
expatRealloc_(void *ptr, size_t size) {
	return gtlsspMarshler->realloc(gtlsspMarshler, ptr, size);
}

static void
expatFree_(void *ptr) {
	if (ptr) gtlsspMarshler->realloc(gtlsspMarshler, ptr, 0);
}

