static void
prsElmRec_init_(xml_prsElmRec* pElmRec, xml_marshaller* pMarshaller, const char* pElmName, const char** ppAttrs) {
	const xml_typeFactory* pFactory = pMarshaller->pFactory_;
	char strBuf[16];
	memset(pElmRec, 0, sizeof(xml_prsElmRec));
	snprintf(strBuf, sizeof(strBuf) - 1, "%d", gtlssIdCnt++);
	pElmRec->typeId_ = SDBMHash_(0, pElmName);
	cstr_init_(pMarshaller, &pElmRec->contentAccum_);
	switch(pElmRec->typeId_) {
[@lua --output element construction code
	-- Block following a `case <h>u:` label: allocate, apply attribute
	-- defaults, dispatch attributes through a (collision-safe) inner switch,
	-- then construct. Reused verbatim for the distinct path and wrapped in a
	-- strcmp confirm on the rare colliding path.
	local function elmBody(node)
		local body, elm, obj = stringBuffer:new(),
			'pElmRec->element_.'..node.name..'_', 'pElm->'
		body:append(table.concat({
			' {\n',
			'\t\txml_', node.name, '* pElm = AllocateElement(xml_', node.name, ', &', elm, ', pFactory);\n',
			'\t\tpElm->eid_ = SDBMHash_(pElmRec->typeId_, strBuf);\n',
		}))
		table.map(node.attributes, function(name, attrib)
			if attrib.default then
				local at = c_narrowCType(attrib.type, attrib.facets)
				body:append(reindent(at.binding.unmarshal.statement(
					'"'..attrib.default..'"', at.buildVar(obj, name)),
					'\t\t\t'))
			end
		end)
		if next(node.attributes) then
			local attrKeys = {}
			table.map(node.attributes, function(n, _) attrKeys[#attrKeys+1] = n end)
			-- Match on the attribute's local name. For a namespaced schema expat
			-- expands a qualified attr to "uri:local", so strip the prefix; for
			-- a non-namespaced schema dispatch on *ppAttrs directly (unchanged).
			local scrut = docRootNS and 'pAttrLocal' or '*ppAttrs'
			local function attrStmt(name)
				local a = node.attributes[name]
				local at = c_narrowCType(a.type, a.facets)
				return reindent(at.binding.unmarshal.statement('*(ppAttrs + 1)',
					at.buildVar(obj, name)), '\t\t\t\t')
			end
			local function attrCase(name)
				return '\t\t\tcase '..hashU(name)..':\n'
					..attrStmt(name)..'\t\t\t\tbreak;\n'
			end
			body:append('\t\tfor ( ; *ppAttrs ; ppAttrs+=2) {\n')
			if docRootNS then
				body:append('\t\t\tconst char* pAttrLocal = strrchr(*ppAttrs, '
					..'\':\') ? strrchr(*ppAttrs, \':\') + 1 : *ppAttrs;\n')
			end
			body:append('\t\t\tswitch(SDBMHash_(0, '..scrut..')) {\n')
			body:append(sdbmCases(scrut, attrKeys, attrCase, attrStmt, '\t\t\t'))
			body:append('\t\t\tdefault:break;\n\t\t\t}\n\t\t}\n')
		end
		body:append(table.concat({
			'\t\tConstructElement(xml_', node.name, ', pElm, pFactory);\n',
			'\t\tbreak;\n\t\t}\n',
		}))
		return body:str()
	end
	local elmKeys, byName = {}, {}
	table.map(depOrderSansRoot, function(_, n)
		elmKeys[#elmKeys+1] = n.name
		byName[n.name] = n
	end)
	local function elmCase(k)
		return '\tcase '..hashU(k)..':'..elmBody(byName[k])
	end
	return table.concat({
		sdbmCases('pElmName', elmKeys, elmCase,
			function(k) return elmBody(byName[k]) end, '\t'),
		'\tdefault: break;\n\t}\n',
		'\t\tXML_UNUSED_ARG(ppAttrs);\n\t\t(void)pFactory;\n}\n',
	})
]
static void
prsElmRec_destory_(xml_prsElmRec* pElmRec, xml_marshaller* pMarshaller) {
	const xml_typeFactory* pFactory = pMarshaller ? pMarshaller->pFactory_ : NULL;
	if (pElmRec) {
		switch(pElmRec->typeId_) {
[@lua -- output element record destructor function
	local outbuf = stringBuffer:new()
	table.map(depOrderByHash, function(_, node)
		-- output case statement for element
		outbuf:append(table.concat({'\t\tcase ', hashU(node.name), ':\n',}))
		-- output destructor for each attribute (3-tab indent under the case;
		-- scalar delete.statement is empty, so skip its indentation entirely)
		local elm = 'pElmRec->element_.'..node.name..'_'
		local objName = elm..'.'
		table.map(node.attributes, function(name, attrib)
			local attribType = c_narrowCType(attrib.type, attrib.facets)
			local stmt = attribType.delete.statement(
				attribType.buildVar(objName, name))
			if stmt ~= '' then outbuf:append('\t\t\t'..stmt) end
		end)
		-- output destructor for content
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			local stmt = contentType.delete.statement(
				contentType.buildVar(objName, "Content"))
			if stmt ~= '' then outbuf:append('\t\t\t'..stmt) end
		end
		-- route element-level teardown through the factory (no-op by default)
		outbuf:append(table.concat({
			'\t\t\tDestroyElement(xml_', node.name, ', &', elm, ', pFactory);\n',
			'\t\t\tbreak;\n',
		}))
	end)
	return outbuf:str()
]		default: break;
		}
		(void)pFactory;
		cstr_destroy_(pMarshaller, &pElmRec->contentAccum_);
	}
}

[@lua -- output facet validators (D2): range/length/enum, no-op when nil
	-- A field is numeric if its C type name is an (u)intN_t/float/double.
	local function isNumeric(c_type)
		local n = c_type.c_type.name()
		return n:match('int%d+_t$') ~= nil
			or n == 'float' or n == 'double' or n == 'long double'
	end
	-- Emit checks reading `expr` (the unmarshalled field) for one facet set.
	local function cChecks(c_type, expr, facets)
		local out = stringBuffer:new()
		-- fail unless all `oks` hold (joined by `op`); drops nil entries
		local function guard(op, oks)
			local kept = {}
			table.map(oks, function(_, v) if v then kept[#kept+1] = v end end)
			if #kept > 0 then
				out:append('\tif (!('..table.concat(kept, op)..')) return 1;\n')
			end
		end
		local len = '(int)strlen('..expr..')'
		table.map(facets_checks(facets), function(_, c)
			if c.kind == 'range' then
				guard(' && ', {c.lo and expr..' >= '..c.lo,
					c.hi and expr..' <= '..c.hi})
			elseif c.kind == 'length' then
				guard(' && ', {c.exact and len..' == '..c.exact,
					c.min and len..' >= '..c.min, c.max and len..' <= '..c.max})
			elseif c.kind == 'enum' then
				if isNumeric(c_type) then
					-- numeric enum: compare the parsed value, not its string
					local ors = {}
					table.map(c.values, function(_, v) ors[#ors+1] = expr..' == '..v end)
					guard(' || ', ors)
				else
					-- string enum: collision-safe sdbm switch over the allowed
					-- set. A hit breaks (falls to later checks); a miss hits
					-- `default: return 1`. The confirm is the strcmp in the
					-- merged colliding case; distinct values need no strcmp.
					out:append('\tswitch (SDBMHash_(0, '..expr..')) {\n')
					out:append(sdbmCases(expr, c.values,
						function(v) return '\tcase '..hashU(v)..': break;\n' end,
						function(_) return '' end, '\t'))
					out:append('\tdefault: return 1;\n\t}\n')
				end
			end
		end)
		return out:str()
	end
	local outbuf = stringBuffer:new()
	table.map(depOrderSansRoot, function(_, node)
		local body = stringBuffer:new()
		if node.content.facets then
			local ct = c_narrowCType(node.content.type, node.content.facets)
			body:append(cChecks(ct, ct.buildVar('pObj->', 'Content'),
				node.content.facets))
		end
		table.map(node.attributes, function(name, attr)
			if attr.facets then
				local at = c_narrowCType(attr.type, attr.facets)
				body:append(cChecks(at, at.buildVar('pObj->', name), attr.facets))
			end
		end)
		if 0 == #body:str() then return end
		node._hasValidator = true
		outbuf:append(table.concat({
			'static int\nvalidate_', node.name,
			'_(const xml_', node.name, '* pObj) {\n',
			body:str(), '\treturn 0;\n}\n\n',
		}))
	end)
	return outbuf:str()
]
static uint32_t
prsElmRec_id_(xml_prsElmRec* pElmRec) {
	if (pElmRec) {
		switch(pElmRec->typeId_) {
[@lua -- output element id return
	local outbuf = stringBuffer:new()
	table.map(depOrderByHash, function(_, node)
		outbuf:append(table.concat({
			'\t\tcase ', hashU(node.name), ':\n',
			'\t\t\t return pElmRec->element_.', node.name, '_.eid_;\n',
		}))
	end)
	return outbuf:str()
]		default: break;
		}
	}
	return 0;
}

static void
prsElmRec_invoke_(xml_prsElmRec* pElmRec, xml_marshaller* pMarshaller, const uint32_t parentId) {
	if (pElmRec) {
		switch(pElmRec->typeId_) {
[@lua -- output element content assignment and data notification invocation
	local outbuf = stringBuffer:new()
	table.map(depOrderByHash, function(_, node)
		outbuf:append(table.concat({'\t\tcase ', hashU(node.name), ':\n'}))
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			outbuf:append(reindent(contentType.binding.unmarshal.statement(
				'cstr_cstr_(&pElmRec->contentAccum_)',
				contentType.buildVar('pElmRec->element_.'..node.name..'_.',
					'Content')), '\t\t\t'))
		end
		-- facet validation (D2): abort on an invalid value
		if node._hasValidator then
			outbuf:append(table.concat({
				'\t\t\tif (validate_', node.name,
				'_(&pElmRec->element_.', node.name, '_)) {\n',
				'\t\t\t\tfprintf(stderr, "', node.name,
				': facet validation failed\\n");\n',
				'\t\t\t\tabort();\n\t\t\t}\n',
			}))
		end
		outbuf:append(table.concat({
			'\t\t\tpMarshaller->unmarshal_', node.name, '(pMarshaller, &pElmRec->element_.', node.name, '_, parentId);\n',
		}))
		outbuf:append('\t\t\tbreak;\n')
	end)
	return outbuf:str()
]		default: break;
		}
	}
	/* work around potentially unused arguments warnings */
	XML_UNUSED_ARG(pMarshaller);
	XML_UNUSED_ARG(parentId);
}

static void
prsElmRec_appendContent_(xml_marshaller* pMarshaller, xml_prsElmRec* pElmRec, const char* pContent, int sz) {
	if (pElmRec) {
		pElmRec->contentAccum_.used_ -= 1;
		buffer_append_(pMarshaller, &pElmRec->contentAccum_, pContent, sz);
		buffer_append_(pMarshaller, &pElmRec->contentAccum_, "", 1);
	}
}

static void
expatStartElementHandler_(void* pCtx, 
									 const XML_Char* pName, 
									 const XML_Char** ppattrs) {
	const char* pElmName = strrchr(pName, ':') ? strrchr(pName, ':') + 1: pName;
	xml_marshaller* pMarshaller = (xml_marshaller*)pCtx;
	xml_prsElmRec elemRec;
	prsElmRec_init_(&elemRec, pMarshaller, pElmName, ppattrs);
	prsElmStack_push_(pMarshaller, &pMarshaller->prsElmStk_, elemRec);
}

static void
expatEndElementHandler_(void* pCtx, const XML_Char* pName) {
	xml_marshaller* pMarshal	= (xml_marshaller*)pCtx;
	xml_prsElmRec*	pBufTop		= prsElmStack_pop_(&pMarshal->prsElmStk_);
	const uint32_t	parentId	= prsElmRec_id_(prsElmStack_top_(&pMarshal->prsElmStk_));
	prsElmRec_invoke_(pBufTop, pMarshal, parentId);
	prsElmRec_destory_(pBufTop, pMarshal);
	XML_UNUSED_ARG(pName);
}

static void
expatCharacterDataHandler_(void* pCtx, const XML_Char* pStr, int len) {
	xml_marshaller* pMarshal = (xml_marshaller*)pCtx;
	xml_prsElmRec* pBufTop = prsElmStack_top_(&pMarshal->prsElmStk_);
	/* append it to current data */
	prsElmRec_appendContent_(pMarshal, pBufTop, pStr, len);
}

void
xml_unmarshal(xml_marshaller* pMarshaller, const xml_buffer* pBuf, int isDocEnd) {
	static const XML_Memory_Handling_Suite memSuite = {
		expatMalloc_,
		expatRealloc_,
		expatFree_,
	};
	gtlsspMarshler =  pMarshaller;
	/* initialize if needed */
	if (NULL == pMarshaller->pParser_) {
		pMarshaller->pParser_ = XML_ParserCreate_MM("utf-8", &memSuite, ":");
		XML_SetUserData(pMarshaller->pParser_, pMarshaller);
		XML_SetElementHandler(pMarshaller->pParser_, expatStartElementHandler_, expatEndElementHandler_);
		XML_SetCharacterDataHandler(pMarshaller->pParser_, expatCharacterDataHandler_);
		buffer_init_(pMarshaller, &pMarshaller->prsElmStk_);
	}
	XML_Parse(pMarshaller->pParser_, (const char *)pBuf->pBuf_, pBuf->used_, isDocEnd);
	/* clean up properly */
	if (isDocEnd) {
		XML_ParserFree(pMarshaller->pParser_);
		pMarshaller->pParser_ = NULL;
		buffer_destroy_(pMarshaller, &pMarshaller->prsElmStk_);
	}
}
