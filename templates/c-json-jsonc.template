/* Codegen pairs sdbm_hash(literal) with this seed-0 runtime hash so enum
   validation can switch on the hash instead of a strcmp chain. */
JSON_NO_UNUSED_WARNING
static uint32_t SDBMHash_(uint32_t hash, const char* pName) {
	for (; *pName; ++pName)
		hash = *pName + (hash << 6) + (hash << 16) - hash;
	return hash;
}

static inline void buffer_init_(json_marshaller* pMarshaller, json_buffer* pBuf) {
	pBuf->pBuf_ = pMarshaller->realloc(pMarshaller, pBuf->pBuf_, 256);
	pBuf->size_ = 256;
	pBuf->used_ = 0;
}

static inline void buffer_append_(json_marshaller* pMarshaller, json_buffer* pBuf, const void* restrict pBlk, uint32_t size) {
	const uint32_t totalSz = size + pBuf->used_;
	if (totalSz >= pBuf->size_) {
		pBuf->pBuf_ = pMarshaller->realloc(pMarshaller, pBuf->pBuf_, (pBuf->size_) ? pBuf->size_ <<= 1 : (pBuf->size_ = 256));
	}
	memcpy(pBuf->pBuf_ + pBuf->used_, pBlk, size);
	pBuf->used_ += size;
}

