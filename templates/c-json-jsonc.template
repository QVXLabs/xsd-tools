			outbuf:append(table.concat({
				'\tif (0 == validate_', node.name, '_(pObj)) {\n',
				'\t\tpMarshaller->unmarshal_', node.name, '(pMarshaller, pObj, parentId);\n',
				'\t}\n',
			}))
		else
			outbuf:append('\tpMarshaller->unmarshal_'..node.name..'(pMarshaller, pObj, parentId);\n')
		end
		table.map(node.attributes, function(name, attrib)
			local attribType = c_narrowCType(attrib.type, attrib.facets)
			outbuf:append(table.concat({
				'\t', attribType.delete.statement(attribType.buildVar(objName, name)),
			}))
		end)
		if next(node.content) then
			local contentType = c_narrowCType(node.content.type, node.content.facets)
			outbuf:append(table.concat({
				'\t', contentType.delete.statement(contentType.buildVar(objName, 'Content')),
			}))
		end
		outbuf:append('\tpObj = DestroyElement('..node.name..', pObj, pMarshaller, pFactories);\n')
		outbuf:append('}\n\n')
	end)
	return outbuf:str()
]
void json_unmarshal_ex(json_marshaller* pMarshaller, const json_buffer* pBuf, int isDocEnd, const json_[@lua return schemaName]_factories* pFactories) {
	struct json_object* pRoot = json_tokener_parse((const char*)pBuf->pBuf_);
	struct json_object* pField;
	JSON_UNUSED_ARG(pField);
	JSON_UNUSED_ARG(isDocEnd);
	if (NULL == pFactories)
		pFactories = json_[@lua return schemaName]_default_factories();
	if (pRoot) {
[@lua -- dispatch root-level elements
	local outbuf = stringBuffer:new()
	table.map(schema.types[schema.root].dependents, function(_, child)
		outbuf:append(table.concat({
			'\t\tif (json_object_object_get_ex(pRoot, "', child.name, '", &pField)) {\n',
			'\t\t\tunmarshalElm_', child.name, '_(pMarshaller, pField, pFactories, 0);\n',
			'\t\t}\n',
		}))
	end)
	return outbuf:str()
]		json_object_put(pRoot);
	}
}

void json_unmarshal(json_marshaller* pMarshaller, const json_buffer* pBuf, int isDocEnd) {
	json_unmarshal_ex(pMarshaller, pBuf, isDocEnd, json_[@lua return schemaName]_default_factories());
}
