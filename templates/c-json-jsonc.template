/* The marshal call chain visits elements without passing the parent json
 * object, so each built element is registered under its name's hash and looked
 * up by its parent's hash when attaching. Element names are unique in the tree
 * (c_safeNames), so a flat hash->object registry is sufficient. */
typedef struct {
	uint32_t			m_hash;
	struct json_object*	m_pObj;
} json_regEntry;

static void _registry_put(json_marshaller* pMarshaller, uint32_t hash, struct json_object* pObj) {
	json_regEntry entry = { hash, pObj };
	_buffer_append(pMarshaller, &pMarshaller->m_registry, &entry, sizeof(entry));
}

static struct json_object* _registry_get(json_marshaller* pMarshaller, uint32_t hash) {
	const json_regEntry* pEnd = (const json_regEntry*)(pMarshaller->m_registry.m_pBuf + pMarshaller->m_registry.m_used);
	const json_regEntry* pItr = (const json_regEntry*)pMarshaller->m_registry.m_pBuf;
	struct json_object* pRet = NULL;
	for (; pItr < pEnd; ++pItr)
		if (pItr->m_hash == hash)
			pRet = pItr->m_pObj;	/* last writer wins */
	return pRet;
}

