json_buffer json_marshal_flush(json_marshaller* pMarshaller, int isDocEnd) {
	json_buffer retBuf = { NULL, 0, 0 };
	const char* restrict pStr = pMarshaller->pRoot_
		? json_object_to_json_string_ext(pMarshaller->pRoot_, JSON_C_TO_STRING_PLAIN)
		: "{}";
	buffer_init_(pMarshaller, &retBuf);
	retBuf.used_ = 0;
	buffer_append_(pMarshaller, &retBuf, pStr, (uint32_t)strlen(pStr) + 1);
	retBuf.used_ -= 1;
	if (isDocEnd && pMarshaller->pRoot_) {
		json_object_put(pMarshaller->pRoot_);
		pMarshaller->pRoot_ = NULL;
	}
	return retBuf;
}

