json_buffer json_marshal_flush(json_marshaller* pMarshaller, int isDocEnd) {
	json_buffer retBuf = { NULL, 0, 0 };
	const char* pStr = pMarshaller->m_pRoot
		? json_object_to_json_string_ext(pMarshaller->m_pRoot, JSON_C_TO_STRING_PLAIN)
		: "{}";
	_buffer_init(pMarshaller, &retBuf);
	retBuf.m_used = 0;
	_buffer_append(pMarshaller, &retBuf, pStr, (uint32_t)strlen(pStr) + 1);
	retBuf.m_used -= 1;
	if (isDocEnd && pMarshaller->m_pRoot) {
		json_object_put(pMarshaller->m_pRoot);
		pMarshaller->m_pRoot = NULL;
		_buffer_destroy(pMarshaller, &pMarshaller->m_registry);
	}
	return retBuf;
}

