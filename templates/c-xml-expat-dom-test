#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <assert.h>
#include <expat.h>
#include "xml_[@lua return schemaNameStripped()].h"
/* ------------ */
static const char kInputXml_[] =
	"<?xml version=\"1.0\" encoding=\"UTF-8\" ?>\n"
[@lua
local out = {}
local str = outputTestXml(schema)
for i = 0,string.len(str), 64 do
   out[#out + 1] = "\t\""..string.sub(str, i, i+63).."\""
end
return table.concat(out,"\n")..";"
]

int main(void) {
  char *pMarshalledDoc;
  xml_typelist *pItr;  
  xml_typelist * pDoc = xml_unmarshal(kInputXml_, strlen(kInputXml_), NULL);
  /* verify marshalling */
  pMarshalledDoc = xml_marshal(pDoc, NULL);
  assert(!strcmp(kInputXml_, pMarshalledDoc));
  /* clean up */
  xml_destroy(&pDoc, NULL);  
  free(pMarshalledDoc);
  return 0;
}

