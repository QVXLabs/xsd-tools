[@lua --include and transform old format
	include 'shared/trnsfrm_old'
	schema = trnsfrm_oldFmt(schema)
][@lua --include any shared 'helper' templates
	return include 'shared/schemaEx'
][@lua --include facet helpers
	include 'shared/facets'
][@lua --include xsd to c type mapping
	return include 'c-xml-expat-sax/c_type_info'
][@lua --generate helper globals
	-- must match the identifier assignment in the c-xml-expat template exactly,
	-- so seed c_safeNames with the same C keyword + member-name reserved set.
	local C_KEYWORDS = {}
	for w in ('auto break case char const continue default do double else enum '
		..'extern float for goto if inline int long register restrict return '
		..'short signed sizeof static struct switch typedef union unsigned void '
		..'volatile while eid Content'):gmatch('%S+') do
		C_KEYWORDS[w] = true
	end
	schema = schema.c_safeNames(C_KEYWORDS)
	-- collapse orphaned duplicate/ref dependents onto their ident-bearing
	-- representative (shared/schemaEx) so the marshal-driver walk uses the same
	-- identifiers as the header.
	schema.canonicalizeDeps()
	uniqueXSDTypes = schema.uniqueTypes()
	-- map xsd types to unique c-types
	uniqueCTypes = {}
	table.map(uniqueXSDTypes, function(_, v)
		local ctype = c_type_info[v]
		-- complex/element type names have no scalar binding; skip them
		if not ctype then return end
		uniqueCTypes[ctype] = ctype
		if 'c_list' == ctype.type then
			local baseType = ctype.baseType()
			uniqueCTypes[baseType] = baseType
		end
	end)
	typeSansRoot = table.filter(schema.types, function(k,v) return v.name ~= schema.root and v or nil end)
][@lua -- create friendly root schema name
	schemaName = schema.types[schema.root].name:gsub("_xsd$", "")
]
#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <assert.h>
#include "xml_[@lua return schemaName].h"

[@lua -- output test data
	local outbuf = stringBuffer:new()
	-- find all list types so that they can be declared in C as two stages
	local listTypes = table.filter(uniqueCTypes, function(_,v) return 'c_list' == v.type and v or nil end)
	-- generate a reverse mapping from list 1st stage declarations to list type
	local listTypeVarMap = {}
	local ndx = 1
	table.map(listTypes, function(_,v)
		listTypeVarMap[v] = 'list'..ndx
		ndx = ndx + 1
	end)
	-- output declaration of the first stage for lists ie list values
	table.map(listTypes, function(_,v)
		outbuf:append(v.test.subDef(listTypeVarMap[v]))
	end)
	-- output stage declarations of objects (main declarations)
	local ID = 1
	table.map(typeSansRoot, function(_, node)
		-- build list of attributes to output test values for
		valTbl = {'.eid_ = '..tostring(ID)}
		local prcssType = function(member, xsdType)
			local c_type = c_narrowCType(xsdType.type, xsdType.facets)
			if "c_list" == c_type.type then
				local cVarName = listTypeVarMap[c_type]
				table.insert(valTbl, c_type.buildVar('.',member)..' = '..c_type.test.assign(cVarName))
			else
				table.insert(valTbl, c_type.buildVar('.',member)..' = '..c_type.test.assign(xsdType.facets))
			end
		end
		table.map(node.attributes, function(_, attr) prcssType(attr.ident, attr) end)
		if next(node.content) then
			prcssType("Content", node.content)
		end
		outbuf:append(table.concat({
			"static const xml_", node.ident, " ", node.ident, "Tst = {", table.concat(valTbl, ','),"};\n",
		}));
		-- inc the ID
		ID = ID + 1
	end)
	return outbuf:str()
]

static void* reallocCb(struct xml_marshaller* pMarshaller, void* pMem, size_t size) {
	(void)pMarshaller;
	return realloc(pMem, size);
}

[@lua -- output unmarshal functions
	local outbuf = stringBuffer:new()
	table.map(typeSansRoot, function(_, node)
		outbuf:append(table.concat({
			"static void unmarshal_", node.ident, "(struct xml_marshaller* pMarshaller, const xml_", node.ident, "* pObj, uint32_t parent) {\n",
			"\t(void)pMarshaller;\n",
			"\t(void)parent;\n",
			"\t(void)pObj;\n",
		}))
		local prcssType = function(member, xsdtype)
			local c_type = c_narrowCType(xsdtype.type, xsdtype.facets)
			outbuf:append(c_type.test.assert(c_type.buildVar('pObj->', member), c_type.buildVar(node.ident..'Tst'..'.', member)))
		end
		table.map(node.attributes, function(_, attr) prcssType(attr.ident, attr) end)
		if next(node.content) then
			prcssType("Content", node.content)
		end
		outbuf:append("}\n")
	end)
	return outbuf:str()
]

int main(void) {
	xml_buffer output;
	xml_marshaller mrshllr = { 
		.realloc = reallocCb,
[@lua --output unmarshal function assignments
	local tbl = {}
	table.map(typeSansRoot, function(_, node)
		table.insert(tbl, "\t\t.unmarshal_"..node.ident.." = unmarshal_"..node.ident)
	end)
	return table.concat(tbl, ",\n")
]
	};
	/* test marshalling */
[@lua --output marshalling statements
	local outbuf = stringBuffer:new()
	local rootHasDeps = next(schema.types[schema.root].dependents)
	-- the entry returns the document's callback struct (now a pointer)
	if rootHasDeps then
		outbuf:append('\tconst xml_marshal_'..schema.types[schema.root].ident
			..'* ret0 = xml_marshal(&mrshllr);\n')
	else
		outbuf:append('\txml_marshal(&mrshllr);\n')
	end
	-- Drive the fluent marshaller depth-first. A recursive type is its own
	-- ancestor; cap re-entry at twice per active path so the self/mutual
	-- recursion edge is exercised while the synthesised document stays finite.
	local seqId = 0
	local onPath = {}
	local function marshalChildren(parentVar, node)
		table.map(node.dependents, function(_, child)
			if next(child.dependents) then
				if (onPath[child.ident] or 0) >= 2 then return end
				onPath[child.ident] = (onPath[child.ident] or 0) + 1
				seqId = seqId + 1
				local v = 'ret'..seqId
				outbuf:append('\tconst xml_marshal_'..child.ident..'* '..v..' = '
					..parentVar..'->marshal_'..child.ident
					..'(&mrshllr, &'..child.ident..'Tst);\n')
				marshalChildren(v, child)
				onPath[child.ident] = onPath[child.ident] - 1
			else
				outbuf:append('\t'..parentVar..'->marshal_'..child.ident
					..'(&mrshllr, &'..child.ident..'Tst);\n')
			end
		end)
	end
	if rootHasDeps then
		marshalChildren('ret0', schema.types[schema.root])
	end
	return outbuf:str()
]	output = xml_marshal_flush(&mrshllr, 1);
	/* test unmarshalling */
	xml_unmarshal(&mrshllr, &output, 1);
	/* clean up */
	output.pBuf_ = realloc(output.pBuf_, 0);
	return 0;
}
