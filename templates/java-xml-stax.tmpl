][@lua --c-safe names & dependency order (mirror python-sax)
	-- handle custom template arguments
	if __CMD_ARGS__["-h"] then
		dbgPrint("Optional arguments for java-xml-stax template")
		dbgPrint("-package <java package name for generated classes>")
		os.exit()
	end
	javaPKGName = __CMD_ARGS__["-package"] or "com.mobitv.app"
	include 'java-xml-stax/java_safe_name'
	schema = schema.c_safeNames()
	depOrder = schema.sortDependencies()
	depOrderSansRoot = table.filter(depOrder, function(k,v)
		return v.name ~= schema.root and v or nil end)
