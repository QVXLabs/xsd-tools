package [@lua return javaPKGName];

import java.util.ArrayList;
import java.util.List;
import javax.xml.stream.XMLStreamReader;
import javax.xml.stream.XMLStreamWriter;
import javax.xml.stream.XMLStreamException;
import javax.xml.stream.XMLStreamConstants;

/* Base element: text buffer + ordered children + the StAX pull loop. */
public abstract class Element {
	protected final StringBuilder _buf = new StringBuilder();
	protected final List<Element> _children = new ArrayList<Element>();
	protected Factory _factory;

	public abstract String localName();
	protected void readAttributes(XMLStreamReader r) {}
	protected void readContent() {}
	protected void marshalAttributes(XMLStreamWriter w)
			throws XMLStreamException {}
	protected void marshalContent(XMLStreamWriter w)
			throws XMLStreamException {}

	public List<Element> children() { return _children; }

	public void marshal(XMLStreamWriter w) throws XMLStreamException {
		w.writeStartElement(localName());
		marshalAttributes(w);
		marshalContent(w);
		for (Element c : _children) {
			c.marshal(w);
		}
		w.writeEndElement();
	}

	/* Called with the reader positioned on this element's START_ELEMENT. */
	public void unmarshal(XMLStreamReader r) throws XMLStreamException {
		readAttributes(r);
		while (r.hasNext()) {
			int ev = r.next();
			if (ev == XMLStreamConstants.START_ELEMENT) {
				Element child = _factory.create(r.getLocalName());
				_children.add(child);
				child.unmarshal(r);
			} else if (ev == XMLStreamConstants.CHARACTERS
					|| ev == XMLStreamConstants.CDATA) {
				_buf.append(r.getText());
			} else if (ev == XMLStreamConstants.END_ELEMENT) {
				readContent();
				return;
			}
		}
	}
}

