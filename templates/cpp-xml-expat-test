/* A marshaller whose on_<name> hooks assert the unmarshalled element matches
   the expected test instance (round-trip equality). */
class Checker : public Marshaller {
public:
[@lua
	local outbuf = stringBuffer:new()
	table.map(typeSansRoot, function(_, node)
		outbuf:append('\tvoid on_'..node.name..'(const '..node.name
			..'& obj) override {\n')
		outbuf:append('\t\t'..node.name..' exp = make_'..node.name..'();\n')
		table.map(node.attributes, function(name, a)
			local ct = cpp_narrowCType(a.type, a.facets)
			-- make_ always populates the optional, so both sides deref safely
			if attrNullable(a) then
				outbuf:append(ct.test.assert('(*obj.'..name..'_)',
					'(*exp.'..name..'_)'))
			else
				outbuf:append(ct.test.assert('obj.'..name..'_',
					'exp.'..name..'_'))
			end
		end)
		if next(node.content) then
			local ct = cpp_narrowCType(node.content.type, node.content.facets)
			outbuf:append(ct.test.assert('obj.content_', 'exp.content_'))
		end
		outbuf:append('\t}\n')
	end)
