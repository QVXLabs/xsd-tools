/* Round-trip driver: build a sample tree, marshal it to XML via
 * fast-xml-parser, unmarshal back through the overridable Factory, re-marshal,
 * and print true/false per top-level root element (the harness greps stdout for
 * "false"). Both marshals share one builder, so equality is byte-exact. */

import { Document } from "./Document";
import { Element } from "./Element";
[@lua
