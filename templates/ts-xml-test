[@lua -- a builder function per complex type, mirroring the Java driver
	local outbuf = stringBuffer:new()
	local depOrder = schema.sortDependencies()
	local depOrderSansRoot = table.filter(depOrder, function(k, v)
		return v.name ~= schema.root and v or nil end)
	-- Facet-aware sample so the built value passes the emitted validation;
	-- fall back to the type's random generator otherwise.
	local function sampleFor(ti, facets)
		if facets then
			local s
			if ti.tsType == "bigint" then
				s = facets_sampleInt(facets)
				if s then s = "BigInt(" .. s .. ")" end
			elseif ti.tsType == "number" then
				s = facets_sampleInt(facets)
			else
				s = facets_sampleString(facets)
				if s then s = '"' .. s .. '"' end
			end
			if s then return s end
		end
		return ti.test.assign()
	end
	table.map(depOrderSansRoot, function(_, node)
		local hasContent = next(node.content) ~= nil
		local tn = tsSafeName(node.name)
		outbuf:append(table.concat({
			"function build_", node.name, "(): ", tn, " {\n",
			"\tconst e = new ", tn, "();\n",
		}))
		table.map(node.attributes, function(an, attr)
			local ti = ts_type_info[attr.type]
			outbuf:append(table.concat({
				"\te._", an, " = ", sampleFor(ti, attr.facets), ";\n",
			}))
		end)
		if hasContent then
			local ti = ts_type_info[node.content.type]
			outbuf:append(table.concat({
				"\te._text = ", sampleFor(ti, node.content.facets), ";\n",
			}))
		end
		table.map(node.dependents, function(_, dep)
			outbuf:append(table.concat({
				"\te.children.push(build_", dep.name, "());\n",
			}))
		end)
		outbuf:append("\treturn e;\n}\n\n")
	end)
	return outbuf:str()
]
