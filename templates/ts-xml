import { XMLParser, XMLBuilder } from "fast-xml-parser";
import { Element, FxpNode, ATTR_PREFIX } from "./Element";
import { Factory } from "./Factory";

/* Shared parser/builder options: preserveOrder keeps the node order stable and
 * the attribute prefix is symmetric, so a re-marshal of a parsed tree is
 * byte-identical to the original. */
const FXP_OPTIONS = {
	ignoreAttributes: false,
	attributeNamePrefix: ATTR_PREFIX,
	preserveOrder: true,
	parseTagValue: false,
	parseAttributeValue: false,
	trimValues: false,
	suppressEmptyNode: true,
};

/* Document-level marshal/unmarshal via fast-xml-parser. Unmarshal routes
 * element creation through the (overridable) Factory. */
export class Document {
	private readonly factory: Factory;
	private readonly parser: XMLParser;
	private readonly builder: XMLBuilder;

	constructor(factory: Factory = new Factory()) {
		this.factory = factory;
		this.parser = new XMLParser(FXP_OPTIONS);
		this.builder = new XMLBuilder(FXP_OPTIONS);
	}

	marshal(root: Element): string {
		return this.builder.build([root.toNode()]);
	}

	unmarshal(xml: string): Element | undefined {
		const nodes = this.parser.parse(xml) as FxpNode[];
		for (const node of nodes) {
			const tag = Object.keys(node).find((k) => k !== ":@");
			if (tag === undefined) continue;
			const root = this.factory.create(tag);
			if (root) {
				root.readNode(node);
				return root;
			}
		}
		return undefined;
	}
}

