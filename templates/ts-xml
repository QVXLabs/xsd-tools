/* fast-xml-parser preserveOrder node: an element is `{ <tag>: child[], ":@"?:
 * attrs }`, a text run is `{ "#text": string }`. Both parse and build use this
 * shape so round-trip equality holds (attribute order, whitespace, self-closing
 * tags all stay stable across marshal -> parse -> marshal). */
export interface FxpNode {
	[key: string]: FxpNode[] | Record<string, string> | string;
}

export const ATTR_PREFIX = "@_";
export const TEXT_KEY = "#text";

/* Base element: ordered children + the (overridable) factory used to build
 * child elements during unmarshal. Leaf types carry text via `_text`. */
export abstract class Element {
	children: Element[] = [];
	factory: Factory | undefined;

	abstract localName(): string;

	/* Target-namespace URI for qualified elements; undefined = no namespace. */
	namespaceURI(): string | undefined { return undefined; }

	/* Attribute map (incl. any xmlns:* on the root) for the start tag. */
	protected marshalAttributes(): Record<string, string> { return {}; }
	protected readAttributes(_attrs: Record<string, string>): void {}
	/* Inline text content of a leaf element, or undefined for no text. */
	protected marshalText(): string | undefined { return undefined; }
	protected readText(_text: string): void {}
	/* Throw on a facet violation (D contract). */
	validate(): void {}

	/* Build this element's preserveOrder node. */
	toNode(): FxpNode {
		const inner: FxpNode[] = [];
		const text = this.marshalText();
		if (text !== undefined) {
			inner.push({ [TEXT_KEY]: text });
		}
		for (const c of this.children) {
			inner.push(c.toNode());
		}
		const node: FxpNode = { [this.localName()]: inner };
		const attrs = this.marshalAttributes();
		const keys = Object.keys(attrs);
		if (keys.length > 0) {
			const prefixed: Record<string, string> = {};
			for (const k of keys) {
				prefixed[ATTR_PREFIX + k] = attrs[k];
			}
			node[":@"] = prefixed;
		}
		return node;
	}

	/* Populate from a parsed preserveOrder node; recurse via the factory. */
	readNode(node: FxpNode): void {
		const tag = this.localName();
		const inner = node[tag] as FxpNode[];
		const rawAttrs = node[":@"] as Record<string, string> | undefined;
		if (rawAttrs) {
			const attrs: Record<string, string> = {};
			for (const k of Object.keys(rawAttrs)) {
				attrs[k.startsWith(ATTR_PREFIX) ? k.slice(ATTR_PREFIX.length) : k]
					= rawAttrs[k];
			}
			this.readAttributes(attrs);
		}
		let text = "";
		for (const child of inner) {
			if (TEXT_KEY in child) {
				text += String(child[TEXT_KEY]);
				continue;
			}
			const localName = Object.keys(child)[0];
			const e = this.factory!.create(localName);
			if (e) {
				this.children.push(e);
				e.readNode(child);
			}
		}
		if (text.length > 0) {
			this.readText(text);
		}
		this.validate();
	}
}

