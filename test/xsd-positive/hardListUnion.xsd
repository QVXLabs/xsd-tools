<?xml version="1.0"?>
<schema>
	<simpleType name="smallInt">
		<restriction base="int">
			<minInclusive value="0"/>
			<maxInclusive value="100"/>
		</restriction>
	</simpleType>

	<simpleType name="intList">
		<list itemType="smallInt"/>
	</simpleType>

	<simpleType name="sizeOrAuto">
		<union memberTypes="int string"/>
	</simpleType>

	<element name="data">
		<complexType>
			<sequence>
				<element name="samples" type="intList"/>
				<element name="size" type="sizeOrAuto"/>
			</sequence>
		</complexType>
	</element>
</schema>
