<?xml version="1.0"?>
<schema>
	<element name="person">
		<complexType>
			<all>
				<element name="firstName" type="string"/>
				<element name="lastName" type="string"/>
				<element name="age" type="int" minOccurs="0"/>
			</all>
			<attribute name="id" type="string" use="required"/>
		</complexType>
	</element>
</schema>
