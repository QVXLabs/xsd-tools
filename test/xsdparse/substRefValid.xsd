<?xml version="1.0"?>
<schema>
	<element name="head" type="integer"/>
	<element name="member" type="int" substitutionGroup="head"/>
	<element name="narrow" substitutionGroup="head">
		<simpleType>
			<restriction base="int"/>
		</simpleType>
	</element>
	<element name="root">
		<complexType>
			<sequence>
				<element ref="member"/>
			</sequence>
		</complexType>
	</element>
</schema>
